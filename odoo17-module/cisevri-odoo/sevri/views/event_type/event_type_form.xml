<odoo>
  <data>
    <record model="ir.ui.view" id="view_event_type_form">
      <field name="name">event_type.form</field>
      <field name="model">sev.event_type</field>
      <field name="arch" type="xml">
        <form string="Tipo de Evento">
          <sheet style="background:#f4f6f9;">
            <div class="container-fluid">
              <div class="card border-0 shadow-sm rounded">
                <div class="card-header text-white" style="background: linear-gradient(135deg,#2c3e50,#34495e);">
                  <div class="d-flex justify-content-between align-items-center">
                    <div>
                      <h4 class="mb-0 text-white">Tipo de Evento</h4>
                    </div>
                  </div>
                </div>
                <div class="card-body p-4">
                  <div class="row g-4">
                    <div class="col-lg-6 d-flex">
                      <div class="card border-0 shadow-sm h-100 w-100">
                        <div class="card-header bg-white">
                          <h5 class="mb-0 fw-semibold">
                            <i class="fa fa-info-circle me-1"/>
                            Información General
                          </h5>
                        </div>
                        <div class="card-body">
                          <div class="mb-3">
                            <p class="text-muted small">Nombre</p>
                            <field name="name" nolabel="1"/>
                          </div>
                          <div class="mb-3">
                            <p class="text-muted small">Descripción</p>
                            <field name="description" nolabel="1"/>
                          </div>
                        </div>
                      </div>
                    </div>
                    <div class="col-lg-6 d-flex">
                      <div class="card border-0 shadow-sm h-100 w-100">
                        <div class="card-header bg-white">
                          <h5 class="mb-0 fw-semibold">
                            <i class="fa fa-list me-1"/>
                            Clasificaciones
                          </h5>
                        </div>
                        <div class="card-body">
                          <field name="classifications" nolabel="1">
                            <tree>
                              <field name="description"/>
                              <field name="event_type_id"/>
                              <field name="specifications"/>
                            </tree>
                          </field>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </sheet>
        </form>
      </field>
    </record>
  </data>
</odoo>