<odoo>
  <data>
    <record id="view_sevri_process_tree_readonly" model="ir.ui.view">
      <field name="name">sevri_process.tree</field>
      <field name="model">sev.process</field>
      <field name="arch" type="xml">
        <tree string="Procesos">
          <header>
            <button
              string="Enviar Notificación"
              type="object"
              name="send_notification_email"
              class="btn-primary"
            />
          </header>
          <field name="initial_date" />
          <field name="final_date" />
          <field name="status" widget="badge"
            decoration-success="status == 'active'"
            decoration-danger="status == 'inactive'"
            decoration-warning="status == 'pending'" />
          <field name="activities" />
        </tree>
      </field>
    </record>
  </data>
</odoo>