<odoo>
  <data>
    <record id="view_unit_form" model="ir.ui.view">
      <field name="name">unit.form</field>
      <field name="model">sci.unit</field>
      <field name="arch" type="xml">
        <form string="Unidad">
          <sheet style="background:#f4f6f9;">
            <div class="container-fluid">
              <div class="card border-0 shadow-sm rounded">
                <div class="card-header text-white" style="background: linear-gradient(135deg,#2c3e50,#34495e);">
                  <div class="d-flex justify-content-between align-items-center">
                    <div>
                      <h4 class="mb-0 text-white">Unidad</h4>
                    </div>
                  </div>
                </div>
                <div class="card-body p-4">
                  <div class="row g-4">
                    <div class="col-lg-6 d-flex">
                      <div class="card border-0 shadow-sm h-100 w-100">
                        <div class="card-header bg-white">
                          <h5 class="mb-0 fw-semibold">
                            <i class="fa fa-info-circle me-1"/>
                            Información General
                          </h5>
                        </div>
                        <div class="card-body">
                          <div class="mb-3">
                            <p class="text-muted small">Nombre</p>
                            <field name="name" nolabel="1" placeholder="Ej. Producción"/>
                          </div>
                          <div class="mb-3">
                            <p class="text-muted small">Descripción</p>
                            <field name="description" nolabel="1" widget="text" rows="4"/>
                          </div>
                          <div class="mb-3">
                            <p class="text-muted small">Departamentos</p>
                            <field name="departments" nolabel="1"/>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </sheet>
        </form>
      </field>
    </record>
  </data>
</odoo>