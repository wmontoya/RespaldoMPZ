<odoo>
  <data>
    <!-- Vista en árbol -->
    <record model="ir.ui.view" id="mature_model_answer_tree">
      <field name="name">respuestas.tree</field>
      <field name="model">mm.answer</field>
      <field name="arch" type="xml">
        <tree>
          <field name="department_name" />
          <field name="option_description" />
          <field name="evaluation_id" />
        </tree>
      </field>
    </record>

    <!-- Vista de formulario -->
    <record id="answers_view_form" model="ir.ui.view">
      <field name="name">respuestas.form</field>
      <field name="model">mm.answer</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <div class="container mt-4">
              <div class="card shadow-sm">
                <div class="card-header bg-primary">
                  <h3 class="card-title mb-0 text-white">Información de la Respuesta</h3>
                </div>
                <div class="card-body">
                  <div class="row">
                    <div class="col-12">
                      <div class="mb-3">
                        <label for="department_name" class="form-label fw-bold">Nombre del Departamento</label>
                        <field name="department_name" class="form-control" style="margin-left: 1rem" />
                      </div>
                      <div class="mb-3">
                        <label for="option_value" class="form-label fw-bold">Valor de la Opción</label>
                        <field name="option_value" class="form-control" />
                      </div>
                      <div class="mb-3">
                        <label for="evaluation_id" class="form-label fw-bold">Valor de Evaluación</label>
                        <field name="evaluation_id" class="form-control" />
                      </div>
                      <div class="mb-3">
                        <label for="option_description" class="form-label fw-bold">Descripción de la Opción</label>
                        <field name="option_description" class="form-control" widget="text" rows="4" />
                      </div>
                      <div class="mb-3">
                        <label for="evaluation_id" class="form-label fw-bold">Evaluación</label>
                        <field name="evaluation_id" class="form-control" />
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </sheet>
        </form>
      </field>
    </record>

    <record model="ir.actions.act_window" id="mm_answer_action">
      <field name="name">Respuestas</field>
      <field name="res_model">mm.answer</field>
      <field name="view_mode">tree,form</field>
    </record>
  </data>
</odoo>
