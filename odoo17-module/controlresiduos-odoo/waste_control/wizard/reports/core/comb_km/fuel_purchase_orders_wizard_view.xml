<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <!-- Wizard Form View -->
    <record id="fuel_purchase_orders_wizard_form" model="ir.ui.view">
      <field name="name">fuel.purchase.orders.year.wizard.form</field>
      <field name="model">waste_control.fuel_purchase_orders_wizard</field>
      <field name="arch" type="xml">
        <form string="Reporte de órdenes de compra de combustible">
          <group>
            <group>
              <field name="year" widget="char" size="4" placeholder="Ingrese el año" />
            </group>
          </group>
          <footer>
            <button
              string="Generar reporte"
              name="action_print_report"
              type="object"
              class="btn-primary" />
            <button
              string="Cancelar"
              class="btn-danger"
              special="cancel" />
          </footer>
        </form>
      </field>
    </record>

    <!-- Wizard Action -->
    <record id="fuel_purchase_orders_wizard_action" model="ir.actions.act_window">
      <field name="name">Fuel purchase orders report</field>
      <field name="binding_model_id" ref="model_waste_control_fuel_purchase_orders" />
      <field name="res_model">waste_control.fuel_purchase_orders_wizard</field>
      <field name="view_mode">form</field>
      <field name="target">new</field>
    </record>
  </data>
</odoo>