<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="fuel_consumption_by_plate_wizard_form" model="ir.ui.view">
    <field name="name">fuel.consumption.by.plate.wizard.form</field>
    <field name="model">waste_control.fuel_consumption_by_plate_wizard</field>
    <field name="arch" type="xml">
      <form string="Reporte de consumo de combustible por placa">
        <group>
          <field name="year" widget="char" size="4" placeholder="Ingrese el año" />
        </group>
        <footer>
          <button string="Generar reporte" name="action_print_report" type="object"
            class="btn-primary" />
          <button string="Cancelar" class="btn-danger" special="cancel" />
        </footer>
      </form>
    </field>
  </record>

  <record id="fuel_consumption_by_plate_wizard_action" model="ir.actions.act_window">
    <field name="name">Fuel consumption by plate report</field>
    <field name="type">ir.actions.act_window</field>
    <field name="res_model">waste_control.fuel_consumption_by_plate_wizard</field>
    <field name="view_mode">form</field>
    <field name="view_id" ref="fuel_consumption_by_plate_wizard_form" />
    <field name="target">new</field>
  </record>
</odoo>