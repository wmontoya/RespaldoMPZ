<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <!-- Wizard Form View -->
    <record id="recycling_on_route_wizard_form" model="ir.ui.view">
      <field name="name">recycling.on.route.wizard.form</field>
      <field name="model">waste_control.recycling_on_route_wizard</field>
      <field name="arch" type="xml">
        <form string="Reporte de reciclaje en ruta">
          <group>
            <group>
              <field name="year" widget="char" size="4" placeholder="Ingrese el año" />
            </group>
          </group>
          <footer>
            <button
              string="Generar reporte"
              class="btn-primary"
              type="object"
              name="action_print_report" />
            <button
              string="Cancelar"
              class="btn-danger"
              special="cancel" />
          </footer>
        </form>
      </field>
    </record>

    <!-- Wizard Action -->
    <record id="recycling_on_route_wizard_action" model="ir.actions.act_window">
      <field name="name">Recycling on route report</field>
      <field name="res_model">waste_control.recycling_on_route_wizard</field>
      <field name="view_mode">form</field>
      <field name="target">new</field>
      <field name="binding_model_id" ref="model_waste_control_recycling_on_route" />
    </record>
  </data>
</odoo>