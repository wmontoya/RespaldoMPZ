<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="waste_percentage_wizard_form" model="ir.ui.view">
    <field name="name">waste.percentage.wizard.form</field>
    <field name="model">waste_control.waste_percentage_wizard</field>
    <field name="arch" type="xml">
      <form string="Reporte de porcentaje de residuos">
        <group>
          <field name="year" widget="char" size="4" placeholder="Ingrese el año" />
        </group>
        <footer>
          <button string="Generar reporte" name="action_print_report" type="object"
            class="btn-primary" />
          <button string="Cancelar" class="btn-danger" special="cancel" />
        </footer>
      </form>
    </field>
  </record>

  <record id="waste_percentage_wizard_action" model="ir.actions.act_window">
    <field name="name">Waste percentage report</field>
    <field name="res_model">waste_control.waste_percentage_wizard</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
  </record>
</odoo>