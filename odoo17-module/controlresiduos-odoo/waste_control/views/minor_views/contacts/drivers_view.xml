<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <!-- * Tree View * -->
    <record id="drivers_tree_view" model="ir.ui.view">
      <field name="name">waste_control.drivers.tree</field>
      <field name="model">waste_control.drivers</field>
      <field name="arch" type="xml">
        <tree string="Conductores">
          <field name="name" />
          <field name="license_number" />
          <field name="phone" widget="phone" />
          <field name="mobile" widget="phone" />
          <field name="email" widget="email" />

          <field name="create_uid" string="Fuente" />
          <field name="create_date" />
          <field name="active" widget="boolean_toggle" />
        </tree>
      </field>
    </record>

    <!-- * Form View * -->
    <record id="drivers_form_view" model="ir.ui.view">
      <field name="name">waste_control.drivers.form</field>
      <field name="model">waste_control.drivers</field>
      <field name="arch" type="xml">
        <form string="Detalles del conductor">
          <header />
          <sheet>
            <field name="avatar_128" invisible="1" />
            <field name="image_1920"
              widget='image' class="oe_avatar"
              options='{"preview_image": "avatar_128"}' readonly="1" />

            <div
              class="oe_title">
              <label for="partner_id" class="oe_edit_only" />
              <h1 string="Crear o seleccionar nombre">
                <field name="partner_id" domain="[('is_company', '=', False)]" />
              </h1>
            </div>

            <group
              string="Información de la persona">
              <field name="name" placeholder="Nombre completo" />
              <field name="function" placeholder="Rol" />
              <field name="category_id" widget="many2many_tags"
                options="{'color_field': 'color', 'no_create_edit': True}"
                placeholder="Categoría de persona: Conductor, Empleado, ..." />

              <field name="email" widget="email" placeholder="Correo" />
              <field name="phone" widget="phone"
                placeholder="Formato: +506 2222 2222" />
              <field name="mobile" widget="phone"
                placeholder="Formato: +506 8888 8888" />
            </group>

            <group
              string="Información de conductor">
              <field name="license_number" string="Número de licencia" />
              <field name="details" placeholder="Detalles relevantes" />
            </group>

            <separator />

            <group>
              <field name="active" widget="boolean_toggle" />
            </group>

            <notebook>
              <!-- * Audit fields*  -->
              <page string="Información de modificación">
                <group>
                  <group>
                    <field name="create_date" readonly="1" />
                    <field name="write_date" readonly="1" />
                  </group>
                  <group>
                    <field name="create_uid" string="Fuente" readonly="1" />
                    <field name="write_uid" string="Editor" readonly="1" />
                  </group>
                </group>
              </page>
            </notebook>
          </sheet>
          <!-- * Notes/Messages  * -->
          <div class="oe_chatter">
            <field name="message_ids" />
          </div>
        </form>
      </field>
    </record>

    <!-- * Search view * -->
    <record id="collection_centers_search_view" model="ir.ui.view">
      <field name="name">waste_control.drivers.search</field>
      <field name="model">waste_control.drivers</field>
      <field name="arch" type="xml">
        <search>
          <filter string="Activo" name="filter_active" domain="[('active', '=', True)]" />
          <filter string="Inactivo" name="filter_inactive"
            domain="[('active', '=', False)]" />

          <separator />
          <filter string="Mis registros" name="filter_my_records"
            domain="[('create_uid', '=', uid)]" />

          <group expand="0" string="Agrupado por">
            <filter string="Estado" name="group_by_active"
              context="{'group_by': 'active'}" />
            <filter string="Usuario responsable" name="group_by_user"
              context="{'group_by': 'create_uid'}" />
            <filter string="Fecha de creación" name="group_by_create_date"
              context="{'group_by': 'create_date:month'}" />
          </group>
        </search>
      </field>
    </record>

    <!-- * Action * -->
    <record id="drivers_act_window" model="ir.actions.act_window">
      <field name="name">Conductores</field>
      <field name="type">ir.actions.act_window</field>
      <field name="res_model">waste_control.drivers</field>
      <field name="view_mode">tree,kanban,form</field>
    </record>
  </data>
</odoo>