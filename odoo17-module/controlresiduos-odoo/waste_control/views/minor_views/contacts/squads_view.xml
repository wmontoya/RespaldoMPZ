<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <!-- * Tree View * -->
    <record id="squads_tree_view" model="ir.ui.view">
      <field name="name">waste_control.squads.tree</field>
      <field name="model">waste_control.squads</field>
      <field name="arch" type="xml">
        <tree string="Cuadrillas">
          <field name="person_names" />

          <field name="create_uid" string="Fuente" />
          <field name="create_date" />
          <field name="active" widget="boolean_toggle" />
        </tree>
      </field>
    </record>

    <!-- * Form View * -->
    <record id="squads_form_view" model="ir.ui.view">
      <field name="name">waste_control.squads.form</field>
      <field name="model">waste_control.squads</field>
      <field name="arch" type="xml">
        <form string="Cuadrillas">
          <header />
          <header />
          <sheet>
            <div class="oe_title">
              <label for="partner_ids" class="oe_edit_only" />
              <h1>
                <field name="person_names" />
              </h1>
            </div>

            <group>
              <field name="partner_ids" widget="many2many"
                placeholder="Escriba o seleccione personas, defínalo como equipo">
                <tree>
                  <field name="name" />
                  <field name="email" widget="email" />
                  <field name="active" widget="boolean_toggle" />
                </tree>
                <form>
                  <group>
                    <field name="name" />
                    <field name="email" widget="email" />
                    <field name="phone" widget="phone" />
                    <field name="mobile" widget="phone" />
                  </group>
                </form>
              </field>
            </group>

            <group>
              <field name="details" placeholder="Detalles relevantes" />
            </group>

            <notebook>
              <!-- * Audit fields*  -->
              <page string="Información de modificación">
                <group>
                  <group>
                    <field name="create_date" readonly="1" />
                    <field name="write_date" readonly="1" />
                  </group>
                  <group>
                    <field name="create_uid" string="Fuente" readonly="1" />
                    <field name="write_uid" string="Editor" readonly="1" />
                  </group>
                </group>
              </page>
            </notebook>
          </sheet>
          <!-- * Notes/Messages  * -->
          <div class="oe_chatter">
            <field name="message_ids" />
          </div>
        </form>
      </field>
    </record>

    <!-- * Kanban view * -->
    <record id="squads_kanban_view" model="ir.ui.view">
      <field name="name">waste_control.squads.kanban</field>
      <field name="model">waste_control.squads</field>
      <field name="arch" type="xml">
        <kanban class="o_kanban_example">
          <field name="person_names" />
          <templates>
            <t t-name="kanban-box">
              <div class="oe_kanban_global_click o_kanban_record">
                <div class="o_kanban_primary_left">
                  <div class="o_kanban_record_title">
                    <field name="person_names" />
                  </div>
                </div>
              </div>
            </t>
          </templates>
        </kanban>
      </field>
    </record>

    <!-- * Search view * -->
    <record id="squads_search_view" model="ir.ui.view">
      <field name="name">waste_control.squads.search</field>
      <field name="model">waste_control.squads</field>
      <field name="arch" type="xml">
        <search>
          <filter string="Activo" name="filter_active" domain="[('active', '=', True)]" />
          <filter string="Inactivo" name="filter_inactive"
            domain="[('active', '=', False)]" />

          <separator />
          <filter string="Mis registros" name="filter_my_records"
            domain="[('create_uid', '=', uid)]" />

          <group expand="0" string="Agrupado por">
            <filter string="Estado" name="group_by_active"
              context="{'group_by': 'active'}" />
            <filter string="Usuario responsable" name="group_by_user"
              context="{'group_by': 'create_uid'}" />
            <filter string="Fecha de creación" name="group_by_create_date"
              context="{'group_by': 'create_date:month'}" />
          </group>
        </search>
      </field>
    </record>

    <!-- last element strict -->
    <!-- * Action * -->
    <record id="squads_act_window" model="ir.actions.act_window">
      <field name="name">Cuadrillas</field>
      <field name="type">ir.actions.act_window</field>
      <field name="res_model">waste_control.squads</field>
      <field name="view_mode">kanban,tree,form</field>
    </record>
  </data>
</odoo>