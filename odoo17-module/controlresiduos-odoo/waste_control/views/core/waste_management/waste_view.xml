<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <!-- * Tree View * -->
    <record id="waste_tree_view" model="ir.ui.view">
      <field name="name">waste_control.waste.tree</field>
      <field name="model">waste_control.waste</field>
      <field name="arch" type="xml">
        <tree string="Residuos">
          <!-- Main fields -->
          <field name="date" widget="date" />
          <field name="tons" />
          <field name="weighing_time" widget="float_time" />

          <!-- Relations -->
          <field name="products_id" />
          <field name="types_of_waste_id" />
          <field name="routes_id" string="Ruta" />
          <field name="historic_vehicles_id" string="Número de placa" />

          <!-- Computed fields -->
          <field name="month" />
          <field name="year" widget="char" />

          <field name="create_uid" string="Fuente" />
          <field name="create_date" />
          <field name="active" widget="boolean_toggle" />
        </tree>
      </field>
    </record>

    <!-- * Form View * -->
    <record id="waste_form_view" model="ir.ui.view">
      <field name="name">waste_control.waste.form</field>
      <field name="model">waste_control.waste</field>
      <field name="arch" type="xml">
        <form string="Residuos">
          <header />
          <sheet>
            <group>
              <!-- Main fields -->
              <group string="Información principal">
                <field name="date" widget="date" placeholder="Selecciona la fecha" />
                <field name="tons" placeholder="Ingrese toneladas" />
                <field name="weighing_time" widget="float_time"
                  placeholder="Ingrese la hora del pesaje" />
              </group>

              <!-- Relations -->
              <group string="Referencias">
                <field name="products_id" placeholder="Escriba o seleccione" />
                <field name="types_of_waste_id" placeholder="Escriba o seleccione" />
                <field name="routes_id" string="Ruta" placeholder="Escriba o seleccione" />
                <field name="historic_vehicles_id" placeholder="Escriba o seleccione" />
              </group>

              <!-- Computed fields -->
              <group string="Capacidad y Cálculo">
                <field name="capacity_percentage" widget="progressbar" />
                <field name="is_full_load" widget="boolean_toggle" />
                <field name="month" />
                <field name="year" widget="char" />
              </group>
            </group>

            <separator />

            <group>
              <field name="active" widget="boolean_toggle" />
            </group>

            <notebook>
              <!-- * Audit fields*  -->
              <page string="Información de modificación">
                <group>
                  <group>
                    <field name="create_date" readonly="1" />
                    <field name="write_date" readonly="1" />
                  </group>
                  <group>
                    <field name="create_uid" string="Fuente"
                      readonly="1" />
                    <field name="write_uid" string="Editor" readonly="1" />
                  </group>
                </group>
              </page>
            </notebook>
          </sheet>
          <!-- * Notes/Messages  * -->
          <div class="oe_chatter">
            <field name="message_ids" />
          </div>
        </form>
      </field>
    </record>


    <!-- * Kanban View * -->
    <record id="waste_kanban_view" model="ir.ui.view">
      <field name="name">waste_control.waste.kanban</field>
      <field name="model">waste_control.waste</field>
      <field name="arch" type="xml">
        <kanban>
          <field name="id" />
          <field name="date" />
          <field name="types_of_waste_id" />
          <field name="routes_id" />
          <field name="tons" />
          <templates>
            <t t-name="kanban-box">
              <div class="oe_kanban_global_click">
                <div class="oe_kanban_details">
                  <span class="o_kanban_record_title">
                    <field name="types_of_waste_id" />
                  </span>
                  <div>
                    <field name="date" />
                  </div>
                  <div>
                    <field name="routes_id" />
                  </div>
                  <div>
                    <field name="tons" />toneladas</div>
                </div>
              </div>
            </t>
          </templates>
        </kanban>
      </field>
    </record>


    <!-- * Pivot View * -->
    <record id="waste_pivot_view" model="ir.ui.view">
      <field name="name">waste_control.waste.pivot</field>
      <field name="model">waste_control.waste</field>
      <field name="arch" type="xml">
        <pivot string="Análisis de Residuos" display_quantity="true">
          <field name="routes_id" type="row" />
          <field name="types_of_waste_id" type="row" />
          <field name="date" interval="month" type="col" />
          <field name="tons" type="measure" />
          <field name="capacity_percentage" type="measure" />
        </pivot>
      </field>
    </record>

    <!-- * Graph View * -->
    <record id="waste_graph_view" model="ir.ui.view">
      <field name="name">waste_control.waste.graph</field>
      <field name="model">waste_control.waste</field>
      <field name="arch" type="xml">
        <graph string="Análisis de Residuos" type="bar" stacked="True">
          <field name="date" interval="month" type="row" />
          <field name="types_of_waste_id" type="row" />
          <field name="tons" type="measure" />
        </graph>
      </field>
    </record>

    <!-- * Search view * -->
    <record id="waste_search_view" model="ir.ui.view">
      <field name="name">waste_control.waste.search</field>
      <field name="model">waste_control.waste</field>
      <field name="arch" type="xml">
        <search>
          <filter string="Activo" name="filter_active" domain="[('active', '=', True)]" />
          <filter string="Inactivo" name="filter_inactive"
            domain="[('active', '=', False)]" />

          <filter string="Año actual" name="year_current"
            domain="[('date','&gt;=', (context_today()).strftime('%Y-01-01')), ('date','&lt;=', (context_today()).strftime('%Y-12-31'))]" />

          <filter string="Año anterior" name="year_last"
            domain="[('date','&gt;=', (context_today() - relativedelta(years=1)).strftime('%Y-01-01')), ('date','&lt;=', (context_today() - relativedelta(years=1)).strftime('%Y-12-31'))]" />

          <separator />
          <filter string="Mis registros" name="filter_my_records"
            domain="[('create_uid', '=', uid)]" />

          <group expand="0" string="Agrupado por">
            <filter string="Estado" name="group_by_active"
              context="{'group_by': 'active'}" />
            <filter string="Usuario responsable" name="group_by_user"
              context="{'group_by': 'create_uid'}" />
            <filter string="Fecha de creación" name="group_by_create_date"
              context="{'group_by': 'create_date:month'}" />
          </group>
        </search>
      </field>
    </record>

    <!-- * Action * -->
    <record id="waste_act_window" model="ir.actions.act_window">
      <field name="name">Residuos</field>
      <field name="type">ir.actions.act_window</field>
      <field name="res_model">waste_control.waste</field>
      <field name="context">{'search_default_year_current': 1}</field>
      <field name="view_mode">tree,kanban,form,pivot,graph</field>
      <field name="search_view_id" ref="waste_search_view" />
    </record>
  </data>
</odoo>