<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <!-- * Tree View * -->
    <record id="purchase_orders_ebi_tree_view" model="ir.ui.view">
      <field name="name">waste_control.purchase_orders_ebi.tree</field>
      <field name="model">waste_control.purchase_orders_ebi</field>
      <field name="arch" type="xml">
        <tree string="Orden de compra EBI" decoration-danger="payment_difference != 0">
          <!-- Main fields -->
          <field name="purchase_order" />
          <field name="date"
            widget="date" />
          <field name="tonnages" />

          <field name="cost" widget="monetary" />
          <field name="calculated_cost" widget="monetary" optional="hide" />
          <field name="payment_difference" widget="monetary" optional="show" />
          <field name="currency_id" />

          <field name="notes" />

          <!-- Computed fields -->
          <field
            name="month" />
          <field name="year" widget="char" />

          <field name="create_uid" string="Fuente" />
          <field name="create_date" />
          <field name="active" widget="boolean_toggle" />
        </tree>
      </field>
    </record>

    <!-- * Form View * -->
    <record id="purchase_orders_ebi_form_view" model="ir.ui.view">
      <field name="name">waste_control.purchase_orders_ebi.form</field>
      <field name="model">waste_control.purchase_orders_ebi</field>
      <field name="arch" type="xml">
        <form string="Orden de compra EBI">
          <header />
          <sheet>
            <group>
              <!-- Main fields -->
              <group string="Información principal">
                <field name="purchase_order" placeholder="Ingrese la orden de compra" />
                <field name="date" widget="date" placeholder="Selecciona la fecha" />
                <field name="tonnages" placeholder="Ingrese las toneladas" />
                <field name="cost" widget="monetary" placeholder="Ingrese el costo" />
                <field name="calculated_cost" widget="monetary" />
                <field name="payment_difference" widget="monetary" />
                <field name="currency_id" invisible="1" />
                <field name="notes" placeholder="Ingrese las notas" />
              </group>

              <!-- Computed fields -->
              <group string="Campos calculados">
                <field name="month" />
                <field name="year" widget="char" />
              </group>
            </group>

            <separator />

            <group>
              <field name="active" widget="boolean_toggle" />
            </group>

            <notebook>
              <!-- * Audit fields*  -->
              <page string="Información de modificación">
                <group>
                  <group>
                    <field name="create_date" readonly="1" />
                    <field name="write_date" readonly="1" />
                  </group>
                  <group>
                    <field name="create_uid" string="Fuente"
                      readonly="1" />
                    <field name="write_uid" string="Editor" readonly="1" />
                  </group>
                </group>
              </page>
            </notebook>
          </sheet>
          <!-- * Notes/Messages  * -->
          <div class="oe_chatter">
            <field name="message_ids" />
          </div>
        </form>
      </field>
    </record>


    <!-- * Kanban View * -->
    <record id="purchase_orders_ebi_kanban_view" model="ir.ui.view">
      <field name="name">waste_control.purchase_orders_ebi.kanban</field>
      <field name="model">waste_control.purchase_orders_ebi</field>
      <field name="arch" type="xml">
        <kanban>
          <field name="id" />
          <field name="date" />
          <field name="purchase_order" />
          <field name="tonnages" />
          <field name="cost" />
          <field name="currency_id" />
          <templates>
            <t t-name="kanban-box">
              <div class="oe_kanban_global_click">
                <div class="oe_kanban_details">
                  <span class="o_kanban_record_title">
                    <field name="purchase_order" />
                  </span>
                  <div>
                    <field name="date" />
                  </div>
                  <div>
                    <field name="tonnages" />toneladas</div>
                  <div>
                    <field name="cost" widget="monetary" />
                  </div>
                </div>
              </div>
            </t>
          </templates>
        </kanban>
      </field>
    </record>


    <!-- * Pivot View * -->
    <record id="purchase_orders_ebi_pivot_view" model="ir.ui.view">
      <field name="name">waste_control.purchase_orders_ebi.pivot</field>
      <field name="model">waste_control.purchase_orders_ebi</field>
      <field name="arch" type="xml">
        <pivot string="Orden de compra EBI" display_quantity="true">
          <field name="date" interval="year" type="col" />
          <field name="date" interval="month" type="col" />
          <field name="tonnages" type="measure" />
          <field name="cost" type="measure" widget="monetary" />
        </pivot>
      </field>
    </record>

    <!-- * Search view * -->
    <record id="purchase_orders_ebi_search_view" model="ir.ui.view">
      <field name="name">waste_control.purchase_orders_ebi.search</field>
      <field name="model">waste_control.purchase_orders_ebi</field>
      <field name="arch" type="xml">
        <search>
          <filter string="Activo" name="filter_active" domain="[('active', '=', True)]" />
          <filter string="Inactivo" name="filter_inactive"
            domain="[('active', '=', False)]" />

          <filter string="Año actual" name="year_current"
            domain="[('date','&gt;=', (context_today()).strftime('%Y-01-01')), ('date','&lt;=', (context_today()).strftime('%Y-12-31'))]" />

          <filter string="Año anterior" name="year_last"
            domain="[('date','&gt;=', (context_today() - relativedelta(years=1)).strftime('%Y-01-01')), ('date','&lt;=', (context_today() - relativedelta(years=1)).strftime('%Y-12-31'))]" />

          <separator />
          <filter string="Mis registros" name="filter_my_records"
            domain="[('create_uid', '=', uid)]" />

          <group expand="0" string="Agrupado por">
            <filter string="Estado" name="group_by_active"
              context="{'group_by': 'active'}" />
            <filter string="Usuario responsable" name="group_by_user"
              context="{'group_by': 'create_uid'}" />
            <filter string="Fecha de creación" name="group_by_create_date"
              context="{'group_by': 'create_date:month'}" />
          </group>
        </search>
      </field>
    </record>

    <!-- * Action * -->
    <record id="purchase_orders_ebi_act_window" model="ir.actions.act_window">
      <field name="name">Orden de compra EBI</field>
      <field name="type">ir.actions.act_window</field>
      <field name="res_model">waste_control.purchase_orders_ebi</field>
      <field name="context">{'search_default_year_current': 1}</field>
      <field name="view_mode">tree,kanban,form,pivot</field>
      <field name="search_view_id" ref="purchase_orders_ebi_search_view" />
    </record>
  </data>
</odoo>