<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <!-- * Tree View * -->
    <record id="buenos_aires_tonnages_tree_view" model="ir.ui.view">
      <field name="name">waste_control.buenos_aires_tonnages.tree</field>
      <field name="model">waste_control.buenos_aires_tonnages</field>
      <field name="arch" type="xml">
        <tree string="Tonelajes Buenos Aires">
          <!-- Main fields -->
          <field name="billing_date" widget="date" />
          <field name="tons" />
          <field name="ticket" />

          <!-- Relations -->
          <field name="historic_vehicles_id" string="Número de placa" />
          <field name="drivers_id" string="Nombre de conductor" />

          <!-- Computed fields -->
          <field name="month" />
          <field name="year" widget="char" />

          <field name="create_uid" string="Fuente" />
          <field name="create_date" />
          <field name="active" widget="boolean_toggle" />
        </tree>
      </field>
    </record>

    <!-- * Form View * -->
    <record id="buenos_aires_tonnages_form_view" model="ir.ui.view">
      <field name="name">waste_control.buenos_aires_tonnages.form</field>
      <field name="model">waste_control.buenos_aires_tonnages</field>
      <field name="arch" type="xml">
        <form string="Tonelajes Buenos Aires">
          <header />
          <sheet>
            <group>
              <!-- Main fields -->
              <group string="Información principal">
                <field name="billing_date" widget="date"
                  placeholder="Selecciona la fecha de facturación" />
                <field name="tons" placeholder="Ingrese toneladas" />
                <field name="notes" placeholder="Ingrese las notas" />
                <field name="ticket" placeholder="Ingrese el número de ticket" />
              </group>

              <!-- Relations -->
              <group string="Referencias">
                <field name="historic_vehicles_id" placeholder="Escriba o seleccione" />
                <field name="drivers_id" placeholder="Escriba o seleccione" />
              </group>

              <!-- Computed fields -->
              <group string="Campos calculados">
                <field name="month" />
                <field name="year" widget="char" />
              </group>
            </group>

            <separator />

            <group>
              <field name="active" widget="boolean_toggle" />
            </group>

            <notebook>
              <!-- * Audit fields*  -->
              <page string="Información de modificación">
                <group>
                  <group>
                    <field name="create_date" readonly="1" />
                    <field name="write_date" readonly="1" />
                  </group>
                  <group>
                    <field name="create_uid" string="Fuente"
                      readonly="1" />
                    <field name="write_uid" string="Editor" readonly="1" />
                  </group>
                </group>
              </page>
            </notebook>
          </sheet>
          <!-- * Notes/Messages  * -->
          <div class="oe_chatter">
            <field name="message_ids" />
          </div>
        </form>
      </field>
    </record>


    <!-- * Kanban View * -->
    <record id="buenos_aires_tonnages_kanban_view" model="ir.ui.view">
      <field name="name">waste_control.buenos_aires_tonnages.kanban</field>
      <field name="model">waste_control.buenos_aires_tonnages</field>
      <field name="arch" type="xml">
        <kanban>
          <field name="id" />
          <field name="billing_date" />
          <field name="historic_vehicles_id" />
          <field name="tons" />
          <field name="ticket" />
          <templates>
            <t t-name="kanban-box">
              <div class="oe_kanban_global_click">
                <div class="oe_kanban_details">
                  <span class="o_kanban_record_title">
                    <field name="historic_vehicles_id" />
                  </span>
                  <div>
                    <field name="billing_date" />
                  </div>
                  <div>
                    <field name="ticket" />
                  </div>
                  <div>
                    <field name="tons" />Toneladas</div>
                </div>
              </div>
            </t>
          </templates>
        </kanban>
      </field>
    </record>


    <!-- * Pivot View * -->
    <record id="buenos_aires_tonnages_pivot_view" model="ir.ui.view">
      <field name="name">waste_control.buenos_aires_tonnages.pivot</field>
      <field name="model">waste_control.buenos_aires_tonnages</field>
      <field name="arch" type="xml">
        <pivot string="Tonelajes Buenos Aires" display_quantity="true">
          <field name="billing_date" interval="year" type="col" />
          <field name="billing_date" interval="month" type="col" />
          <field name="tons" type="measure" />
        </pivot>
      </field>
    </record>

    <!-- * Search view * -->
    <record id="buenos_aires_tonnages_search_view" model="ir.ui.view">
      <field name="name">waste_control.buenos_aires_tonnages.search</field>
      <field name="model">waste_control.buenos_aires_tonnages</field>
      <field name="arch" type="xml">
        <search>
          <filter string="Activo" name="filter_active" domain="[('active', '=', True)]" />
          <filter string="Inactivo" name="filter_inactive"
            domain="[('active', '=', False)]" />

          <filter string="Año actual" name="year_current"
            domain="[('billing_date','&gt;=', (context_today()).strftime('%Y-01-01')), ('billing_date','&lt;=', (context_today()).strftime('%Y-12-31'))]" />

          <filter string="Año anterior" name="year_last"
            domain="[('billing_date','&gt;=', (context_today() - relativedelta(years=1)).strftime('%Y-01-01')), ('billing_date','&lt;=', (context_today() - relativedelta(years=1)).strftime('%Y-12-31'))]" />

          <separator />
          <filter string="Mis registros" name="filter_my_records"
            domain="[('create_uid', '=', uid)]" />

          <group expand="0" string="Agrupado por">
            <filter string="Estado" name="group_by_active"
              context="{'group_by': 'active'}" />
            <filter string="Usuario responsable" name="group_by_user"
              context="{'group_by': 'create_uid'}" />
            <filter string="Fecha de creación" name="group_by_create_date"
              context="{'group_by': 'create_date:month'}" />
          </group>
        </search>
      </field>
    </record>

    <!-- * Action * -->
    <record id="buenos_aires_tonnages_act_window" model="ir.actions.act_window">
      <field name="name">Tonelajes Buenos Aires</field>
      <field name="type">ir.actions.act_window</field>
      <field name="res_model">waste_control.buenos_aires_tonnages</field>
      <field name="context">{'search_default_year_current': 1}</field>
      <field name="view_mode">tree,kanban,form,pivot</field>
      <field name="search_view_id" ref="buenos_aires_tonnages_search_view" />
    </record>
  </data>
</odoo>