<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <!-- * Tree View * -->
    <record id="bills_tree_view" model="ir.ui.view">
      <field name="name">waste_control.bills.tree</field>
      <field name="model">waste_control.bills</field>
      <field name="arch" type="xml">
        <tree string="Facturas">
          <field name="bill_number" />
          <field name="date" widget="date" />
          <field name="amount" widget="monetary" />
          <field name="currency_id" />

          <field name="create_uid" string="Fuente" />
          <field name="create_date" />
          <field name="active" widget="boolean_toggle" />
        </tree>
      </field>
    </record>

    <!-- * Form View * -->
    <record id="bills_form_view" model="ir.ui.view">
      <field name="name">waste_control.bills.form</field>
      <field name="model">waste_control.bills</field>
      <field name="arch" type="xml">
        <form string="Facturas">
          <header />
          <sheet>
            <group>
              <field name="date" placeholder="Seleccione la fecha de la factura" />
              <field name="bill_number" placeholder="Ingrese el número de factura" />
              <field name="amount" widget="monetary" placeholder="Ingrese el monto" />
              <field name="currency_id" invisible="1" />
            </group>

            <notebook>
              <page string="Órdenes de compra de combustible">
                <field name="fuel_purchase_orders_ids">
                  <tree>
                    <field name="date" widget="date" />
                    <field name="liters" />
                    <field name="amount" widget="monetary" />

                    <field name="bills_id" />
                    <field name="historic_vehicles_id" />
                    <field name="active" widget="boolean_toggle" />
                  </tree>
                </field>
              </page>

              <!-- * Audit fields*  -->
              <page string="Información de modificación">
                <group>
                  <group>
                    <field name="create_date" readonly="1" />
                    <field name="write_date" readonly="1" />
                  </group>
                  <group>
                    <field name="create_uid" string="Fuente"
                      readonly="1" />
                    <field name="write_uid" string="Editor" readonly="1" />
                  </group>
                </group>
              </page>
            </notebook>
          </sheet>
          <!-- * Notes/Messages  * -->
          <div class="oe_chatter">
            <field name="message_ids" />
          </div>
        </form>
      </field>
    </record>

    <!-- * Kanban View * -->
    <record id="bills_kanban_view" model="ir.ui.view">
      <field name="name">waste_control.bills.kanban</field>
      <field name="model">waste_control.bills</field>
      <field name="arch" type="xml">
        <kanban>
          <field name="id" />
          <field name="bill_number" />
          <field name="date" />
          <field name="amount" />
          <field name="currency_id" />
          <templates>
            <t t-name="kanban-box">
              <div class="oe_kanban_global_click">
                <div class="oe_kanban_details">
                  <span class="o_kanban_record_title">
                    <field name="bill_number" />
                  </span>
                  <div>
                    <field name="date" />
                  </div>
                  <div>
                    <field name="amount" widget="monetary" />
                  </div>
                </div>
              </div>
            </t>
          </templates>
        </kanban>
      </field>
    </record>

    <!-- * Pivot View * -->
    <record id="bills_pivot_view" model="ir.ui.view">
      <field name="name">waste_control.bills.pivot</field>
      <field name="model">waste_control.bills</field>
      <field name="arch" type="xml">
        <pivot string="Facturas" display_quantity="true">
          <field name="date" interval="month" type="col" />
          <field name="create_uid" type="row" />
          <field name="amount" type="measure" />
        </pivot>
      </field>
    </record>

    <!-- * Search view * -->
    <record id="bills_search_view" model="ir.ui.view">
      <field name="name">waste_control.bills.search</field>
      <field name="model">waste_control.bills</field>
      <field name="arch" type="xml">
        <search>
          <filter string="Activo" name="filter_active" domain="[('active', '=', True)]" />
          <filter string="Inactivo" name="filter_inactive"
            domain="[('active', '=', False)]" />

          <filter string="Año actual" name="year_current"
            domain="[('date','&gt;=', (context_today()).strftime('%Y-01-01')), ('date','&lt;=', (context_today()).strftime('%Y-12-31'))]" />

          <filter string="Año anterior" name="year_last"
            domain="[('date','&gt;=', (context_today() - relativedelta(years=1)).strftime('%Y-01-01')), ('date','&lt;=', (context_today() - relativedelta(years=1)).strftime('%Y-12-31'))]" />

          <separator />
          <filter string="Mis registros" name="filter_my_records"
            domain="[('create_uid', '=', uid)]" />

          <group expand="0" string="Agrupado por">
            <filter string="Estado" name="group_by_active"
              context="{'group_by': 'active'}" />
            <filter string="Usuario responsable" name="group_by_user"
              context="{'group_by': 'create_uid'}" />
            <filter string="Fecha de creación" name="group_by_create_date"
              context="{'group_by': 'create_date:month'}" />
          </group>
        </search>
      </field>
    </record>

    <!-- * Action * -->
    <record id="bills_act_window" model="ir.actions.act_window">
      <field name="name">Facturas</field>
      <field name="type">ir.actions.act_window</field>
      <field name="res_model">waste_control.bills</field>
      <field name="context">{'search_default_year_current': 1}</field>
      <field name="view_mode">tree,kanban,form,pivot</field>
      <field name="search_view_id" ref="bills_search_view" />
    </record>
  </data>
</odoo>