<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <!-- * Tree View * -->
    <record id="fuel_purchase_orders_tree_view" model="ir.ui.view">
      <field name="name">waste_control.fuel_purchase_orders.tree</field>
      <field name="model">waste_control.fuel_purchase_orders</field>
      <field name="arch" type="xml">
        <tree string="Órdenes de compra de combustible" decoration-danger="amount &lt; 0">
          <field name="date" widget="date" />
          <field name="liters" />
          <field name="amount" widget="monetary" />
          <field name="currency_id" />

          <!-- Relations -->
          <field name="bills_id" string="Número de factura" />
          <field name="historic_vehicles_id" string="Número de placa" />
          <field name="applicant_id" string="Nombre del solicitante" />

          <field name="create_uid" string="Fuente" />
          <field name="create_date" />
          <field name="active" widget="boolean_toggle" />
        </tree>
      </field>
    </record>

    <!-- * Form View * -->
    <record id="fuel_purchase_orders_form_view" model="ir.ui.view">
      <field name="name">waste_control.fuel_purchase_orders.form</field>
      <field name="model">waste_control.fuel_purchase_orders</field>
      <field name="arch" type="xml">
        <form string="Órdenes de compra de combustible">
          <header />
          <sheet>
            <group>
              <group string="Información de fecha">
                <field name="date" placeholder="Seleccionar fecha" />
                <field name="month" placeholder="Ingrese el mes" />
                <field name="year" widget="char" size="4" placeholder="Ingrese el año, mínimo 1900" />
              </group>

              <!-- Relations  -->
              <group string="Referencias">
                <field name="bills_id" placeholder="Escriba o seleccione" />
                <field name="historic_vehicles_id" placeholder="Escriba o seleccione" />
                <field name="applicant_id" placeholder="Escriba o seleccione" />
              </group>
            </group>

            <group string="Información de compra">
              <field name="liters" placeholder="Ingrese la cantidad de litros" />
              <field name="amount" widget="monetary" placeholder="Ingrese el monto" />
              <field name="currency_id" invisible="1" />
              <field name="oc_number" placeholder="Ingrese el numero OC" />
              <field name="coupon" placeholder="Ingrese el cupón" />
            </group>

            <separator />

            <group>
              <field name="active" widget="boolean_toggle" />
            </group>

            <notebook>
              <!-- * Audit fields*  -->
              <page string="Información de modificación">
                <group>
                  <group>
                    <field name="create_date" readonly="1" />
                    <field name="write_date" readonly="1" />
                  </group>
                  <group>
                    <field name="create_uid" string="Fuente"
                      readonly="1" />
                    <field name="write_uid" string="Editor" readonly="1" />
                  </group>
                </group>
              </page>
            </notebook>
          </sheet>
          <!-- * Notes/Messages  * -->
          <div class="oe_chatter">
            <field name="message_ids" />
          </div>
        </form>
      </field>
    </record>

    <!-- Pivot View -->
    <record id="fuel_purchase_orders_pivot_view" model="ir.ui.view">
      <field name="name">waste_control.fuel_purchase_orders.pivot</field>
      <field name="model">waste_control.fuel_purchase_orders</field>
      <field name="arch" type="xml">
        <pivot string="Órdenes de compra de combustible" display_quantity="true">
          <!-- (Rows) -->
          <field name="historic_vehicles_id" type="row" />

          <!-- (Columns) -->
          <field name="date" interval="year" type="col" />
          <field name="date" interval="month" type="col" />

          <!-- (Measures) -->
          <field name="liters" type="measure" />
          <field name="amount" type="measure" widget="monetary" />
        </pivot>
      </field>
    </record>

    <!-- * Kanban View * -->
    <record id="fuel_purchase_orders_kanban_view" model="ir.ui.view">
      <field name="name">waste_control.fuel_purchase_orders.kanban</field>
      <field name="model">waste_control.fuel_purchase_orders</field>
      <field name="arch" type="xml">
        <kanban>
          <field name="id" />
          <field name="date" />
          <field name="historic_vehicles_id" />
          <field name="liters" />
          <field name="amount" />
          <field name="currency_id" />
          <templates>
            <t t-name="kanban-box">
              <div class="oe_kanban_global_click">
                <div class="oe_kanban_details">
                  <span class="o_kanban_record_title">
                    <field name="historic_vehicles_id" />
                  </span>
                  <div>
                    <field name="date" />
                  </div>
                  <div>
                    <field name="liters" />L</div>
                  <div>
                    <field name="amount" widget="monetary" />
                  </div>
                </div>
              </div>
            </t>
          </templates>
        </kanban>
      </field>
    </record>

    <!-- * Search view * -->
    <record id="fuel_purchase_orders_search_view" model="ir.ui.view">
      <field name="name">waste_control.fuel_purchase_orders.search</field>
      <field name="model">waste_control.fuel_purchase_orders</field>
      <field name="arch" type="xml">
        <search>
          <field name="year" widget="char" />
          <field name="month" />
          <field name="date" widget="date" />

          <filter string="Activo" name="filter_active" domain="[('active', '=', True)]" />
          <filter string="Inactivo" name="filter_inactive"
            domain="[('active', '=', False)]" />

          <filter string="Año actual" name="year_current"
            domain="[('date','&gt;=', (context_today()).strftime('%Y-01-01')), ('date','&lt;=', (context_today()).strftime('%Y-12-31'))]" />

          <filter string="Año anterior" name="year_last"
            domain="[('date','&gt;=', (context_today() - relativedelta(years=1)).strftime('%Y-01-01')), ('date','&lt;=', (context_today() - relativedelta(years=1)).strftime('%Y-12-31'))]" />

          <separator />
          <filter string="Mis registros" name="filter_my_records"
            domain="[('create_uid', '=', uid)]" />

          <group expand="0" string="Agrupado por">
            <filter string="Estado" name="group_by_active"
              context="{'group_by': 'active'}" />
            <filter string="Usuario responsable" name="group_by_user"
              context="{'group_by': 'create_uid'}" />
            <filter string="Fecha de creación" name="group_by_create_date"
              context="{'group_by': 'create_date:month'}" />
          </group>
        </search>
      </field>
    </record>

    <!-- * Action * -->
    <record id="fuel_purchase_orders_act_window" model="ir.actions.act_window">
      <field name="name">Órdenes de compra de combustible</field>
      <field name="type">ir.actions.act_window</field>
      <field name="res_model">waste_control.fuel_purchase_orders</field>
      <field name="context">{'search_default_year_current': 1}</field>
      <field name="view_mode">tree,kanban,form,pivot</field>
      <field name="search_view_id" ref="fuel_purchase_orders_search_view" />
    </record>
  </data>
</odoo>