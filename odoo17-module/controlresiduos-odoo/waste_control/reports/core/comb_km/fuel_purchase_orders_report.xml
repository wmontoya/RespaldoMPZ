<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <template id="fuel_purchase_orders_report_document">
      <div class="page">
        <h2>Reporte gastos de combustible por mes - año <span t-esc="selected_year" /></h2>
        <p class="text-muted">Fecha del reporte: <span t-esc="report_date" /></p>

        <table class="table table-sm table-bordered">
          <thead>
            <tr class="text-center" style="background-color: #d9d9d9;">
              <th>Mes</th>

              <t t-foreach="month_names" t-as="m_name">
                <th>
                  <span t-esc="m_name" />
                </th>
              </t>

              <th>Total anual</th>
            </tr>
          </thead>

          <tbody>
            <t t-foreach="report_rows" t-as="row">
              <tr>
                <!-- * Column names * -->
                <td class="align-middle text-center" style="background-color: #f2f2f2;">
                  <span t-esc="row['name']" />
                </td>

                <t t-foreach="row['values']" t-as="val">
                  <td class="text-end">
                    <t t-if="row['type'] == 'monetary'">
                      <span t-esc="val"
                        t-options="{'widget': 'monetary', 'display_currency': company_currency}"
                        t-if="val > 0" />
                      <span t-else="">-</span>
                    </t>
                    <t t-else="">
                      <span t-esc="val" t-options="{'widget': 'float', 'precision': 2}"
                        t-if="val > 0" />
                      <span t-else="">-</span>
                    </t>
                  </td>
                </t>

                <td class="text-end" style="background-color: #f4f5ef;">
                  <t t-if="row['type'] == 'monetary'">
                    <span t-esc="row['total']"
                      t-options="{'widget': 'monetary', 'display_currency': company_currency}" />
                  </t>
                  <t t-else="">
                    <span t-esc="row['total']" t-options="{'widget': 'float', 'precision': 2}" />
                  </t>
                </td>
              </tr>
            </t>
          </tbody>
        </table>

        <div class="row mt-4">
          <div class="col-12">
            <span>Total anual del costo:</span>
            <span t-esc="report_rows[1]['total']"
              t-options="{'widget': 'monetary', 'display_currency': company_currency}" />
          </div>
        </div>

      </div>
    </template>

    <!-- Wrapper Template (called by action) -->
    <template id="fuel_purchase_orders_report">
      <t t-call="web.html_container">
        <t t-call="web.external_layout">
          <t t-call="waste_control.fuel_purchase_orders_report_document" />
        </t>
      </t>
    </template>

    <!-- Report Action -->
    <record id="fuel_purchase_orders_report_action" model="ir.actions.report">
      <field name="name">Reporte Orden de compra de combustible</field>
      <field name="model">waste_control.fuel_purchase_orders_wizard</field>
      <field name="report_type">qweb-pdf</field>
      <field name="report_name">waste_control.fuel_purchase_orders_report</field>
      <field name="report_file">waste_control.fuel_purchase_orders_report</field>
      <field name="print_report_name">(f'Reporte_de_Órdenes_de_Compra_de_Combustible_{object.year}')</field>
      <field name="paperformat_id" ref="waste_control.paperformat_landscape" />
    </record>
  </data>
</odoo>