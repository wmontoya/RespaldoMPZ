<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <template id="fuel_consumption_by_plate_report_document">
      <div class="page">
        <h2>Reporte de consumo de combustible por matrícula - año <span t-esc="selected_year" /></h2>
        <p class="text-muted">Fecha del reporte: <span t-esc="report_date" /></p>

        <table class="table table-sm table-bordered">
          <thead>
            <tr class="text-center" style="background-color: #d9d9d9;">
              <th>Vehículo</th>

              <t t-foreach="month_headers" t-as="month">
                <th>
                  <span t-esc="month" />
                </th>
              </t>
              <th>Total</th>
            </tr>
          </thead>

          <tbody>
            <tr t-foreach="rows" t-as="row">
              <td class="align-middle">
                <span t-esc="row['name']" />
              </td>
              <t t-foreach="row['values']" t-as="val">
                <td class="text-end">
                  <span t-esc="val"
                    t-options="{'widget': 'float', 'precision': 3}"
                    t-if="val > 0" />
                  <span t-else="">-</span>
                </td>
              </t>
              <td class="text-end" style="background-color: #f4f5ef;">
                <span t-esc="row['total']"
                  t-options="{'widget': 'float', 'precision': 3}" />
              </td>
            </tr>
          </tbody>
        </table>

        <div class="row mt-4">
          <div class="col-12">
            <p>
              <span>Consumo medio mensual (litros):</span>
              <span t-esc="monthly_average_total"
                t-options="{'widget': 'float', 'precision': 3}" />
            </p>
          </div>
        </div>
      </div>
    </template>

    <template id="fuel_consumption_by_plate_report">
      <t t-call="web.html_container">
        <t t-call="web.external_layout">
          <t t-call="waste_control.fuel_consumption_by_plate_report_document" />
        </t>
      </t>
    </template>

    <record id="fuel_consumption_by_plate_report_action" model="ir.actions.report">
      <field name="name">Consumo de combustible por placa</field>
      <field name="model">waste_control.fuel_consumption_by_plate_wizard</field>
      <field name="report_type">qweb-pdf</field>
      <field name="report_name">waste_control.fuel_consumption_by_plate_report</field>
      <field name="report_file">waste_control.fuel_consumption_by_plate_report</field>
      <field name="print_report_name">(f'Consumo_de_combustible_por_plato_{object.year}')</field>
      <field name="paperformat_id" ref="waste_control.paperformat_landscape" />
    </record>
  </data>
</odoo>