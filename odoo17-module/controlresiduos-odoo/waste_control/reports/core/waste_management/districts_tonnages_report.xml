<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <template id="districts_tonnages_report_document">
      <div class="page">
        <h2>Reporte tonelajes distritales - año <span t-esc="selected_year" /></h2>
        <p class="text-muted">Fecha del reporte: <span t-esc="report_date" /></p>

        <table class="table table-sm table-bordered">
          <thead>
            <tr class="text-center" style="background-color: #d9d9d9;">
              <th>Distrito/ Tipo</th>

              <t t-foreach="month_names" t-as="v_month">
                <th>
                  <span t-esc="v_month" />
                </th>
              </t>

              <th>Total anual</th>
            </tr>
          </thead>

          <tbody>
            <t t-foreach="rows" t-as="row">
              <tr>
                <!-- * Column names * -->
                <td class="align-middle text-center" style="background-color: #f2f2f2;">
                  <span t-esc="row['name']" />
                </td>

                <t t-foreach="row['values']" t-as="val">
                  <td class="text-end">
                    <span t-esc="val" t-options="{'widget': 'float', 'precision': 3}" t-if="val > 0" />
                    <span t-else="">-</span>
                  </td>
                </t>

                <td class="text-end" style="background-color: #f4f5ef;">
                  <span t-esc="row['total']" t-options="{'widget': 'float', 'precision': 3}" />
                </td>
              </tr>
            </t>
          </tbody>
        </table>
      </div>
    </template>

    <template id="districts_tonnages_report">
      <t t-call="web.html_container">
        <t t-call="web.external_layout">
          <t t-call="waste_control.districts_tonnages_report_document" />
        </t>
      </t>
    </template>

    <record id="districts_tonnages_report_action" model="ir.actions.report">
      <field name="name">Reporte de tonelaje de los distritos</field>
      <field name="model">waste_control.districts_tonnages_wizard</field>
      <field name="report_type">qweb-pdf</field>
      <field name="report_name">waste_control.districts_tonnages_report</field>
      <field name="report_file">waste_control.districts_tonnages_report</field>
      <field name="print_report_name">(f'Reporte_Distritos_{object.year}')</field>
      <field name="paperformat_id" ref="waste_control.paperformat_landscape" />
    </record>
  </data>
</odoo>