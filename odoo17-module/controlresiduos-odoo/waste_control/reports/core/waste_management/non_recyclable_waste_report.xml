<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <template id="non_recyclable_waste_report">
    <t t-call="web.html_container">
      <t t-call="web.external_layout">
        <div class="page">
          <h2>Reporte mensual de toneladas de residuos no reciclables por ruta</h2>
          <p class="text-muted">Fecha del reporte: <span t-esc="report_date" /></p>

          <table class="table table-sm table-bordered">
            <thead>
              <tr class="text-center" style="background-color: #d9d9d9;">
                <th>Rutas</th>
                <t t-foreach="months" t-as="month">
                  <th>
                    <span t-esc="month" />
                  </th>
                </t>
                <th>Anual</th>
              </tr>
            </thead>

            <tbody>
              <t t-foreach="rows" t-as="row">
                <tr>
                  <td>
                    <span t-esc="row['name']" />
                  </td>
                  <t t-foreach="row['months']" t-as="val">
                    <td class="text-right">
                      <span t-esc="val" t-options='{"widget": "float", "precision": 2}' />
                    </td>
                  </t>
                  <td class="text-right" style="background-color: #f4f5ef;">
                    <span t-esc="row['annual']" t-options='{"widget": "float", "precision": 2}' />
                  </td>
                </tr>
              </t>
              <!-- Totals -->
              <tr class="font-weight-bold table-active">
                <td>Total</td>
                <t t-foreach="total_monthly" t-as="tm">
                  <td class="text-right">
                    <span t-esc="tm" t-options='{"widget": "float", "precision": 2}' />
                  </td>
                </t>
                <td class="text-right">
                  <span t-esc="total_annual" t-options='{"widget": "float", "precision": 2}' />
                </td>
              </tr>
            </tbody>
          </table>

          <div class="mt-4">
            <p> Promedio mensual de toneladas <span t-esc="monthly_average"
                t-options='{"widget": "float", "precision": 4}' />
            </p>
          </div>
        </div>
      </t>
    </t>
  </template>

  <record id="non_recyclable_waste_report_action" model="ir.actions.report">
    <field name="name">Reporte mensual de toneladas de residuos no reciclables</field>
    <field name="model">waste_control.non_recyclable_waste_wizard</field>
    <field name="report_type">qweb-pdf</field>
    <field name="report_name">waste_control.non_recyclable_waste_report</field>
    <field name="report_file">waste_control.non_recyclable_waste_report</field>
    <field name="binding_model_id" ref="model_waste_control_non_recyclable_waste_wizard" />
    <field name="paperformat_id" ref="waste_control.paperformat_landscape" />
  </record>
</odoo>