<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <template id="private_companies_report_document">
      <div class="page">
        <h2>Reporte control de recaudación de empresas privadas - año <span t-esc="selected_year" /></h2>
        <p class="text-muted">Fecha del reporte: <span t-esc="report_date" /></p>

        <table class="table table-sm table-bordered">
          <thead>
            <tr class="text-center" style="background-color: #d9d9d9;">
              <th>Mes</th>

              <t t-foreach="monthly_data" t-as="month">
                <th>
                  <span t-esc="month['name']" />
                </th>
              </t>
              <th>Total</th>
            </tr>
          </thead>

          <tbody>
            <tr>
              <!-- * Column name * -->
              <td class="align-middle text-center" style="background-color: #f2f2f2;">Toneladas</td>

              <t t-foreach="monthly_data" t-as="month">
                <td class="text-end">
                  <span t-esc="month['tons']"
                    t-options="{'widget': 'float', 'precision': 3}"
                    t-if="month['tons'] > 0" />
                  <span t-else="">-</span>
                </td>
              </t>

              <td class="text-end" style="background-color: #f4f5ef;">
                <span t-esc="annual_tons"
                  t-options="{'widget': 'float', 'precision': 3}" />
              </td>
            </tr>

            <tr>
              <!-- * Column name * -->
              <td class="align-middle text-center" style="background-color: #f2f2f2;">Monto</td>

              <t t-foreach="monthly_data" t-as="month">
                <td class="text-end">
                  <span t-esc="month['amount']"
                    t-options="{'widget': 'monetary', 'display_currency': company_currency}"
                    t-if="month['amount'] > 0" />
                  <span t-else="">-</span>
                </td>
              </t>

              <td class="text-end" style="background-color: #f4f5ef;">
                <span t-esc="annual_amount"
                  t-options="{'widget': 'monetary', 'display_currency': company_currency}" />
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </template>

    <template id="private_companies_report">
      <t t-call="web.html_container">
        <t t-call="web.external_layout">
          <t t-call="waste_control.private_companies_report_document" />
        </t>
      </t>
    </template>

    <record id="private_companies_report_action" model="ir.actions.report">
      <field name="name">Reporte empresas privadas</field>
      <field name="model">waste_control.private_companies_wizard</field>
      <field name="report_type">qweb-pdf</field>
      <field name="report_name">waste_control.private_companies_report</field>
      <field name="report_file">waste_control.private_companies_report</field>
      <field name="print_report_name">(f'Reporte_Compañías_Privadas_{object.year}')</field>
      <field name="paperformat_id" ref="waste_control.paperformat_landscape" />
    </record>
  </data>
</odoo>