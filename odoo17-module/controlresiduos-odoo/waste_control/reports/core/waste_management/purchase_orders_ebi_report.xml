<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <template id="purchase_orders_ebi_report_document">
      <div class="page">
        <h2>Reporte resumido de órdenes de compra de EBI - año <span t-esc="selected_year" /></h2>
        <p class="text-muted">Fecha del reporte: <span t-esc="report_date" /></p>

        <table class="table table-sm table-bordered">
          <thead>
            <tr class="text-center" style="background-color: #d9d9d9;">
              <th />
              <th>Toneladas</th>
              <th>Costo</th>
            </tr>
          </thead>

          <tbody>
            <tr>
              <!-- * Column name * -->
              <td class="align-middle text-center" style="background-color: #f2f2f2;">Total anual</td>

              <td>
                <span t-esc="annual_tonnages"
                  t-options="{'widget': 'float', 'precision': 3}" />
              </td>

              <td>
                <span t-esc="annual_cost"
                  t-options="{'widget': 'monetary', 'display_currency': company_currency}" />
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </template>

    <template id="purchase_orders_ebi_report">
      <t t-call="web.html_container">
        <t t-call="web.external_layout">
          <t t-call="waste_control.purchase_orders_ebi_report_document" />
        </t>
      </t>
    </template>

    <record id="purchase_orders_ebi_report_action" model="ir.actions.report">
      <field name="name">Reporte ordenes de compra EBI</field>
      <field name="model">waste_control.purchase_orders_ebi_wizard</field>
      <field name="report_type">qweb-pdf</field>
      <field name="report_name">waste_control.purchase_orders_ebi_report</field>
      <field name="report_file">waste_control.purchase_orders_ebi_report</field>
      <field name="print_report_name">(f'Reporte_Ordenes_de_Compra_EBI_{object.year}')</field>
      <field name="paperformat_id" ref="waste_control.paperformat_landscape" />
    </record>
  </data>
</odoo>