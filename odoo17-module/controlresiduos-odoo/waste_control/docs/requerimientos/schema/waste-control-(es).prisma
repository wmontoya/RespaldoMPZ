generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "PostgreSQL"
    url      = env("DATABASE_URL")
}

// Modelo de datos Prisma-PostgreSQL. Enfocado al desarrollo en Odoo 17.

//********************************************
// # Entidades menores #
//********************************************

// * categoria: General *

model ResCurrency {
    // Identificación 
    id String @id

    // Información principal 
    nombre  String
    simbolo String

    // Relaciones inversas
    EmpresasPrivadas             EmpresasPrivadas[]
    OrdenesCompra_EBI            OrdenesCompra_EBI[]
    Facturas                     Facturas[]
    OrdenesDeCompraDeCombustible OrdenesDeCompraDeCombustible[]
}

//  (por ejemplo, sinpe, tiquetes, tarjeta, efectivo)
model MesPago {
    // Identificación 
    id String @id

    // Información principal 
    nombre String @unique

    // Relaciones inversas
    EmpresasPrivadas EmpresasPrivadas[]
}

model Productos {
    // Identificación 
    id String @id

    // Información principal 
    nombre String @unique

    detalles String?

    // Relaciones inversas
    Residuos Residuos[]
}

model ProgramasReciclaje {
    // Identificación 
    id String @id

    // Información principal 
    nombre String @unique

    detalles String?

    // Relaciones inversas
    ReciclajePorCampana ReciclajePorCampana[]
}

model Rutas {
    // Identificación 
    id String @id

    // Información principal 
    nombre      String  @unique
    descripcion String?

    // Relaciones inversas
    // Reciclaje               Reciclaje[]
    Residuos               Residuos[]
    EstudioRutas           EstudioRutas[]
    RutasVehiculos         RutasVehiculos[]
    ReciclajeEnRuta        ReciclajeEnRuta[]
    ResiduosCarnicos       ResiduosCarnicos[]
    KilometrajesRecorridos KilometrajesRecorridos[]
}

// (no aprovechable, ordinario, organico)
model TiposResiduos {
    // Identificación 
    id String @id

    // Información principal 
    nombre String @unique

    // Relaciones inversas
    Residuos Residuos[]
}

// * categoria: Ubicaciones *

model Provincias {
    // Identificación 
    id String @id

    // Información principal 
    nombre String @unique

    // Relaciones inversas
    Cantones Cantones[]
}

model Cantones {
    // Identificación 
    id String @id

    // Información principal 
    nombre String @unique

    // Relaciones 
    provincia   Provincias @relation(fields: [provinciaId], references: [id])
    provinciaId String

    // Relaciones inversas
    Distritos Distritos[]
}

model Distritos {
    // Identificación 
    id String @id

    // Información principal 
    nombre String @unique

    // Relaciones 
    canton   Cantones @relation(fields: [cantonId], references: [id])
    cantonId String

    // Relaciones inversas
    Comunidades                 Comunidad[]
    ReciclajePorCampana         ReciclajePorCampana[]
    Reporte_ResiduosComunidades Reporte_ResiduosComunidades[]
}

model Comunidad {
    // Identificación 
    id String @id

    // Información principal 
    nombre String @unique

    // Relaciones 
    distrito   Distritos @relation(fields: [distritoId], references: [id])
    distritoId String

    Reporte_ResiduosComunidades Reporte_ResiduosComunidades[]
}

// * categoria: Contactos Personas y Entidades * 

model Partner {
    // Identificación
    id String @id

    // Información principal
    nombre        String
    funcion       String
    telefono      String
    telefonoMovil String
    email         String

    direccion String

    image_1920 String? // URL de la imagen del contacto

    // Relaciones inversas
    Conductores   Conductores[]
    Supervisores  Supervisores[]
    CentrosAcopio CentrosAcopio[]

    Cuadrillas Cuadrillas[] @relation("CuadrillaMembers")

    OrdenesDeCompraDeCombustible OrdenesDeCompraDeCombustible[]
}

model CentrosAcopio {
    // Identificación 
    id String @id

    // Información principal 
    detalles String?

    // Relaciones 
    centroAcopio   Partner @relation(fields: [centroAcopioId], references: [id])
    centroAcopioId String  @unique

    // ! Calculado
    nombre String // (relacionado) Este campo cambia segun el asocie de la relacion

    // Relaciones inversas
    ReciclajeEnRuta ReciclajeEnRuta[]
}

model Conductores {
    // Identificación 
    id String @id

    // Información principal
    numeroDeLicencia String  @unique
    detalles         String?

    // Relaciones 
    persona   Partner @relation(fields: [personaId], references: [id])
    personaId String  @unique

    // ! Calculado
    nombre String // (relacionado) Este campo cambia segun el asocie de la relacion

    // Relaciones inversas
    RutasVehiculos         RutasVehiculos[]
    EmpresasPrivadas       EmpresasPrivadas[]
    TonelajeBuenosAires    TonelajeBuenosAires[]
    KilometrajesRecorridos KilometrajesRecorridos[]

    // HistoricoVehiculos     HistoricoVehiculos[]
}

model Cuadrillas {
    // Identificación 
    id String @id

    // Información principal 
    detalles String?

    // Relaciones
    personaIds Partner[] @relation("CuadrillaMembers")

    // ! Calculado
    nombresPersonas String @unique // (relacionado) Este campo cambia segun el asocie de la relacion

    //  Relaciones inversas
    KilometrajesRecorridos KilometrajesRecorridos[]
}

model Supervisores {
    // Identificación 
    id String @id

    // Información principal
    areaSupervicion      String
    numeroIdentificacion String  @unique
    detalles             String? // ? Text

    // Relaciones 
    persona   Partner @relation(fields: [personaId], references: [id])
    personaId String  @unique

    // ! Calculado
    nombre String // (relacionado) Este campo cambia segun el asocie de la relacion
}

