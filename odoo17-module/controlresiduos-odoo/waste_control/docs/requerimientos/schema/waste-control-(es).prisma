//********************************************
// # Entidades principales #
//********************************************

// * categoria: (VEHICULOS-RUTAS) *

model HistoricoVehiculos {
    // Identificación 
    id String @id

    // info vehiculo
    numero Int
    placa  String  @unique
    marca  String?
    year   Int?

    // detalles del vehiculo
    capacidadCarga Float? // 6,2
    estado         String? // text 

    // Relaciones
    // conductorId            Int? //  no fijo, entonces quitar?

    // Relaciones inversas
    Residuos                     Residuos[]
    RutasVehiculos               RutasVehiculos[]
    ReciclajeEnRuta              ReciclajeEnRuta[]
    EmpresasPrivadas             EmpresasPrivadas[]
    ResiduosCarnicos             ResiduosCarnicos[]
    ReciclajePorCampana          ReciclajePorCampana[]
    TonelajeBuenosAires          TonelajeBuenosAires[]
    KilometrajesRecorridos       KilometrajesRecorridos[]
    Reporte_ResiduosComunidades  Reporte_ResiduosComunidades[]
    OrdenesDeCompraDeCombustible OrdenesDeCompraDeCombustible[]
}

model EstudioRutas {
    // Identificación 
    id String @id

    numero Int //  unique?

    kilometrosDeLaRuta Float // 6,2

    // Relaciones
    ruta   Rutas?  @relation(fields: [rutaId], references: [id])
    rutaId String?
}

model RutasVehiculos {
    // Identificación 
    id String @id

    numero Int //  unique?

    year           Int?
    capacidadCarga Float? // 6,2

    observaciones String?

    // Relaciones
    vehiculo   HistoricoVehiculos @relation(fields: [vehiculoId], references: [id])
    vehiculoId String

    conductor     Conductores? @relation(fields: [conductoresId], references: [id])
    conductoresId String?

    // ! NUEVO. debe valorar
    ruta   Rutas?  @relation(fields: [rutaId], references: [id]) //  adicional, one2one?
    rutaId String?

    // fecha DateTime? // ? adicionales ?
}

// * categoria: (Comb-KM) *

// ! separar control de factura [listo]
// NEW nuevo modelo
model Facturas {
    // Identificación 
    id String @id

    numeroFactura String   @unique
    fecha         DateTime
    monto         Float // Monetary

    // Relaciones
    moneda   ResCurrency @relation(fields: [monedaId], references: [id])
    monedaId String

    // Relaciones inversas
    OrdenesDeCompraDeCombustible OrdenesDeCompraDeCombustible[]
}

//  unique?
model OrdenesDeCompraDeCombustible {
    // Identificación 
    id String @id

    // Información principal
    fecha DateTime

    litros    Float // 10,3
    monto     Float // Monetary
    numero_OC String?
    cupon     String?

    // Relaciones
    facturas   Facturas @relation(fields: [facturasId], references: [id])
    facturasId String

    nombreSolicitante   Partner? @relation(fields: [nombreSolicitanteId], references: [id])
    nombreSolicitanteId String?

    vehiculo   HistoricoVehiculos? @relation(fields: [vehiculoId], references: [id])
    vehiculoId String?

    moneda   ResCurrency @relation(fields: [monedaId], references: [id])
    monedaId String

    // ! Calculado
    mes  Int // CALCULADO * seleccion
    year Int
}

//  unique?
model KilometrajesRecorridos {
    // Identificación 
    id String @id

    // Información principal
    fecha DateTime?

    kilometrosAlSalir    Int? // kilometros que marca antes de salir
    KilometrosAlRegresar Int? // kilometros que marca al volver, no puede ser menor que el anterior

    residuo     String? // char 50 //  tipo (entidad menor?) y relacion?: 1vs1 o 1vsM
    horasEnRuta Float? // 4,2

    observaciones String?

    // Relaciones
    chofer        Conductores? @relation(fields: [conductoresId], references: [id])
    conductoresId String?

    cuadrilla    Cuadrillas? @relation(fields: [cuadrillasId], references: [id])
    cuadrillasId String?

    vehiculo   HistoricoVehiculos @relation(fields: [vehiculoId], references: [id])
    vehiculoId String

    ruta    Rutas?  @relation(fields: [rutasId], references: [id])
    rutasId String?

    // ! Calculado
    total_km Int? // CALCULADO
}

// ! ********************************************

// * categoria: Residuos y Reciclaje *

//  unique?
model ResiduosCarnicos {
    // Identificación 
    id String @id

    // Información principal 
    fecha      DateTime
    kilogramos Float // 6,2

    // Relaciones
    ruta   Rutas?  @relation(fields: [rutaId], references: [id])
    rutaId String?

    vehiculo   HistoricoVehiculos? @relation(fields: [vehiculoId], references: [id])
    vehiculoId String?

    // ! Calculado
    mes  Int // CALCULADO * seleccion
    year Int
}

//  unique?
model ReciclajeEnRuta {
    // Identificación 
    id String @id

    // Información principal 
    fecha DateTime

    toneladas            Float //  6,3
    otrosNoAprovechables Float? // 6,2

    horasEnRuta Float? // 4,2
    horaPesaje  Float? // 4,2 tiempo

    // Relaciones
    ruta   Rutas?  @relation(fields: [rutaId], references: [id])
    rutaId String?

    vehiculo   HistoricoVehiculos? @relation(fields: [vehiculoId], references: [id])
    vehiculoId String?

    centroAcopio   CentrosAcopio? @relation(fields: [centroAcopioId], references: [id])
    centroAcopioId String?

    // ! Calculado
    mes  Int // calclado * seleccion
    year Int // calclado
}

//  unique?
model ReciclajePorCampana {
    // Identificación 
    id String @id

    // Información principal
    lugar String? // char 50 // finca u otro.

    fecha DateTime

    toneladas Float // 6,3

    // Relaciones
    distrito   Distritos? @relation(fields: [distritoId], references: [id])
    distritoId String?

    programaReciclaje   ProgramasReciclaje? @relation(fields: [programaReciclajeId], references: [id])
    programaReciclajeId String?

    vehiculo   HistoricoVehiculos? @relation(fields: [vehiculoId], references: [id])
    vehiculoId String?

    // ! Calculado
    mes  Int // CALCULADO * seleccion
    year Int
}

// (no aprovechable, ordinario, organico)
//  unique?
model Residuos {
    // Identificación 
    id String @id

    // Información principal 
    fecha DateTime

    toneladas  Float // 6,2
    horaPesaje Float? // 4,2 tiempo

    // Relaciones
    productos   Productos? @relation(fields: [productosId], references: [id])
    productosId String?

    tiposResiduos   TiposResiduos? @relation(fields: [tiposResiduosId], references: [id])
    tiposResiduosId String?

    ruta   Rutas?  @relation(fields: [rutaId], references: [id])
    rutaId String?

    vehiculo   HistoricoVehiculos @relation(fields: [vehiculoId], references: [id])
    vehiculoId String

    // ! Calculado
    mes  Int // CALCULADO * seleccion
    year Int
}

//  unique?
model TonelajeBuenosAires {
    // Identificación 
    id String @id

    // Información principal 
    fechaFacturacion DateTime
    toneladas        Float // 6,3
    notas            String? // text
    boleta           String? // char 10

    // Relaciones
    vehiculo   HistoricoVehiculos @relation(fields: [vehiculoId], references: [id])
    vehiculoId String

    chofer        Conductores? @relation(fields: [conductoresId], references: [id])
    conductoresId String?

    // ! Calculado
    mes Int // CALCULADO

    // Relaciones inversas
}

//  unique?
model OrdenesCompra_EBI {
    // Identificación 
    id String @id

    // Información principal 
    ordenCompra String // char 10
    fecha       DateTime
    tonelajes   Float // 8,2
    costo       Float // Monetary

    notas String? // text/char 50

    // Relaciones
    moneda   ResCurrency @relation(fields: [monedaId], references: [id])
    monedaId String

    // ! Calculado
    mes  Int // CALCULADO * seleccion
    year Int // CALCULADO
}

//  unique?
model EmpresasPrivadas {
    // Identificación 
    id String @id

    // Información principal
    fecha DateTime

    pesoToneladas Float // 6,2

    numeroComprobante String // char 20

    montoCancelar  Float // Monetary
    montoCancelado Float? // Monetary
    diferencia     Float? // Monetary

    observaciones String? // text

    pesoTiquete Float? // 4,1
    desconocido Float? // 4,1 // 

    // Relaciones
    vehiculo   HistoricoVehiculos? @relation(fields: [vehiculoId], references: [id])
    vehiculoId String?

    chofer        Conductores? @relation(fields: [conductoresId], references: [id])
    conductoresId String?

    // sinpe, tiquetes, efectivo, etc
    mePago   MesPago? @relation(fields: [mePagoId], references: [id])
    mePagoId String?

    moneda   ResCurrency @relation(fields: [monedaId], references: [id])
    monedaId String

    // ! Calculado
    mes  Int // CALCULADO * seleccion
    year Int // CALCULADO
}

// : entidad almanenenada?
//  unique?
model Reporte_ResiduosComunidades {
    // Identificación 
    id String @id

    // Información principal
    fecha DateTime

    kilogramos Int?
    toneladas  Float // 6,2

    numeroBoleta_EBI String? // char 10

    factura String? // char 10

    // Relaciones
    vehiculo   HistoricoVehiculos? @relation(fields: [vehiculoId], references: [id])
    vehiculoId String?

    distrito   Distritos? @relation(fields: [distritoId], references: [id])
    distritoId String?

    // Se filtra segun el distrito, si no hay distrito, se asocia a la comunidad y define distrido asociado a la comunidad
    comunidad   Comunidad? @relation(fields: [comunidadId], references: [id])
    comunidadId String?

    // ! Calculado
    dia Int // CALCULADO * seleccion
    mes Int // CALCULADO * seleccion
}
