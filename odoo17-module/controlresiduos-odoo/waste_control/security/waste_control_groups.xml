<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <data>
    <!-- Category -->
    <record model="ir.module.category" id="category_waste_control_roles">
      <field name="name">Roles de control de residuos</field>
      <field name="description">Roles para gestión de control de residuos</field>
      <field name="sequence">1</field>
    </record>

    <!-- Technical group
        -  -->
    <record id="group_technical" model="res.groups">
      <field name="name">Técnico</field>
      <field name="category_id" ref="category_waste_control_roles" />
      <field name="comment">Los usuarios técnicos pueden registrar actividades de gestión de
        residuos</field>
    </record>

    <record id="group_auditor" model="res.groups">
      <field name="name">Auditor</field>
      <field name="category_id" ref="category_waste_control_roles" />
      <field name="comment">Auditor: solo puede revisar todos los registros</field>
    </record>

    <record id="group_editor" model="res.groups">
      <field name="name">Editor</field>
      <field name="category_id" ref="category_waste_control_roles" />
      <field name="comment">Editor: ver y crear tablas resumen y reportes</field>
    </record>

    <record id="group_leadership" model="res.groups">
      <field name="name">Jefatura</field>
      <field name="category_id" ref="category_waste_control_roles" />
      <field name="comment">Jefatura/coordinador: visualización para obtener datos, reportes y
        aportaciones para otros proyectos</field>
    </record>

    <record id="group_it" model="res.groups">
      <field name="name">IT</field>
      <field name="category_id" ref="category_waste_control_roles" />
      <field name="comment">Tecnología de la Información: gestionar parámetros y consultas</field>
    </record>

    <record id="group_coordinator" model="res.groups">
      <field name="name">Coordinador</field>
      <field name="category_id" ref="category_waste_control_roles" />
      <field name="comment">Coordinador: ver y descargar todo, sin edición</field>
    </record>

