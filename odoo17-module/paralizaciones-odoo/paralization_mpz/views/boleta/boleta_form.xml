<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <record id="view_boleta_form" model="ir.ui.view">
      <field name="name">paralization_mpz.boleta.form.bootstrap</field>
      <field name="model">paralization_mpz.boleta</field>
      <field name="arch" type="xml">

        <form string="Boleta de Paralización de Obra">

          <header>
            <button name="action_generar_reporte"
              string="📄 Generar PDF"
              type="object"
              class="btn-primary" />
          </header>

          <sheet style="background-color:#f4f6f9;">

            <!-- HERO -->
            <div class="container-fluid mb-4">
              <div class="row align-items-center p-4 rounded shadow-sm"
                style="background:linear-gradient(135deg,#1f3b57,#2c5282);">

                <div class="col-lg-9">
                  <h2 class="fw-bold mb-1 text-white">
                    BOLETA PARALIZACIÓN DE OBRA
                  </h2>
                  <div class="text-white-50">
                    Municipalidad de Pérez Zeledón
                  </div>
                </div>

                <div class="col-lg-3 text-end">
                  <span class="badge px-3 py-2 bg-light d-inline-flex align-items-center">
                    <span class="text-danger fw-bold fs-4 me-2">Nº</span>
                    <field name="numero_boleta" readonly="1"
                      class="text-danger fw-bold fs-4 mb-0" />
                  </span>
                </div>

              </div>
            </div>

            <!-- FILA 1 -->
            <div class="container-fluid">
              <div class="row g-4">

                <!-- GENERAL -->
                <div class="col-lg-4">
                  <div class="card border-0 shadow-sm h-100">

                    <div class="card-header bg-white">
                      <h5 class="mb-0 fw-semibold">
                        <i class="fa fa-info-circle me-1" /> Información General </h5>
                    </div>

                    <div class="card-body">
                      <div class="row">
                        <!-- Columna izquierda -->
                        <div class="col-md-6">
                          <div class="mb-1">
                            <p class="text-muted small">Consecutivo Digital</p>
                            <field class="w-100" name="consecutivo_digital" nolabel="1" />
                          </div>

                          <div class="mb-1">
                            <p class="text-muted small">Inspector</p>
                            <field class="w-100" name="inspector_id" nolabel="1" />

                          </div>
                          <div class="mb-1">
                            <p class="text-muted small">Fecha</p>
                            <field class="w-100" name="fecha_boleta" nolabel="1" />
                          </div>

                          <div class="mb-1">
                            <p class="text-muted small">Cédula Inspector</p>
                            <field class="w-100" name="inspector_cedula" nolabel="1" />
                          </div>
                        </div>

                        <!-- Columna derecha -->
                        <div class="col-md-6">
                          <div class="mb-3">
                            <p class="text-muted small">Firma Inspector</p>

                            <div
                              class="border rounded p-2 d-flex justify-content-center align-items-center">
                              <field name="inspector_firma"
                                widget="image"
                                class="d-block"
                                nolabel="1" />
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>

                  </div>
                </div>

                <!-- INFRACTOR -->
                <div class="col-lg-8">
                  <div class="card border-0 shadow-sm h-100">

                    <div class="card-header bg-white">
                      <h5 class="mb-0 fw-semibold">
                        <i class="fa fa-user me-1" /> Administrado Infractor </h5>
                    </div>

                    <div class="card-body">

                      <div class="row g-3">

                        <div class="col-md-6">
                          <p class="text-muted small">Nombre</p>
                          <field class="w-100" name="administrador_nombre" nolabel="1" />
                        </div>

                        <div class="col-md-6">
                          <p class="text-muted small">Cédula</p>
                          <field class="w-100" name="administrador_cedula" nolabel="1" />
                        </div>

                        <div class="col-md-6">
                          <p class="text-muted small">Dirección</p>
                          <field class="w-100" name="obra_direccion" nolabel="1" />
                        </div>

                        <div class="col-md-6">
                          <p class="text-muted small">Distrito</p>
                          <field class="w-100" name="obra_distrito_id" nolabel="1" />
                        </div>

                      </div>

                    </div>

                  </div>
                </div>

              </div>
            </div>

            <!-- FILA 2 -->
            <div class="container-fluid mt-4">
              <div class="row g-4">

                <!-- DETALLE OBRA -->
                <div class="col-lg-12">
                  <div class="card border-0 shadow-sm">

                    <div class="card-header bg-white">
                      <h5 class="mb-0 fw-semibold">
                        <i class="fa fa-building me-1" /> Detalle de la Obra </h5>
                    </div>

                    <div class="card-body">

                      <div class="row g-3">

                        <div class="col-md-4">
                          <p class="text-muted small">Área m²</p>
                          <field class="w-100" name="area_m2" nolabel="1" />
                        </div>

                        <div class="col-md-4">
                          <p class="text-muted small">Unidad</p>
                          <field class="w-100" name="unidad_medida" nolabel="1" />
                        </div>

                        <div class="col-md-4">
                          <p class="text-muted small">Metros Frente</p>
                          <field class="w-100" name="metros_frente" nolabel="1" />
                        </div>

                        <div class="col-md-4">
                          <p class="text-muted small">Niveles</p>
                          <field class="w-100" name="cantidad_niveles" nolabel="1" />
                        </div>

                        <div class="col-md-4">
                          <p class="text-muted small">% Avance</p>
                          <field class="w-100" name="porcentaje_avance" nolabel="1" />
                        </div>

                        <div class="col-md-4">
                          <p class="text-muted small">Vía Acceso</p>
                          <field class="w-100" name="via_acceso" nolabel="1" />
                        </div>

                        <div class="col-md-4">
                          <p class="text-muted small">Tipo Piso</p>
                          <field class="w-100" name="tipo_piso_id"
                            nolabel="1"
                            options="{'no_create_edit': True}" />
                        </div>

                        <div class="col-md-4">
                          <p class="text-muted small">Tipo Pared</p>
                          <field class="w-100" name="tipo_pared_id"
                            nolabel="1"
                            options="{'no_create_edit': True}" />
                        </div>

                        <div class="col-md-4">
                          <p class="text-muted small">Tipo Techo</p>
                          <field class="w-100" name="tipo_techo_id"
                            nolabel="1"
                            options="{'no_create_edit': True}" />
                        </div>

                        <div class="col-md-4">
                          <p class="text-muted small">Obedece a</p>
                          <field class="w-100" name="afectacion_legal" nolabel="1" />
                        </div>

                        <div class="col-md-4">
                          <p class="text-muted small">Descripción</p>
                          <field class="w-100" name="descripcion_obra" nolabel="1" />
                        </div>

                        <div class="col-md-4">
                          <p class="text-muted small">Observaciones</p>
                          <field class="w-100" name="observaciones" nolabel="1" />
                        </div>

                      </div>

                    </div>

                  </div>
                </div>

              </div>
            </div>

            <!-- FILA 3 -->
            <div class="container-fluid mt-4">
              <div class="row g-4 align-items-stretch">

                <!-- NOTIFICADO -->
                <div class="col-lg-4 d-flex">
                  <div class="card border-0 shadow-sm h-100 w-100">

                    <div class="card-header bg-white">
                      <h5 class="mb-0 fw-semibold">
                        <i class="fa fa-bell me-1" /> Datos del Notificado </h5>
                    </div>

                    <div class="card-body">
                      <div class="row">
                        <!-- Columna izquierda -->
                        <div class="col-md-6">
                          <div class="mb-3">
                            <p class="text-muted small">Nombre</p>
                            <field class="w-100" name="notificado_nombre" nolabel="1" />
                          </div>
                          <div class="mb-3">
                            <p class="text-muted small">Hora</p>
                            <field class="w-100" name="notificado_hora" nolabel="1" />
                          </div>
                        </div>
                        <!-- Columna derecha -->
                        <div class="col-md-6">
                          <div class="mb-3">
                            <p class="text-muted small">Cédula</p>
                            <field class="w-100" name="notificado_cedula" nolabel="1" />
                          </div>
                          <div class="mb-3">
                            <p class="text-muted small">Acepta Firmar</p>
                            <field class="w-100" name="acepta_firmar" nolabel="1"
                              widget="boolean_toggle" />
                          </div>
                        </div>
                      </div>

                      <div class="mb-3">
                        <p class="text-muted small">Firma</p>

                        <div
                          class="border rounded p-2 d-flex justify-content-center align-items-center">
                          <field name="notificado_firma"
                            widget="image"
                            class="d-block"
                            nolabel="1" />
                        </div>
                      </div>

                    </div>

                  </div>
                </div>

                <!-- TESTIGO -->
                <div class="col-lg-4 d-flex">
                  <div class="card border-0 shadow-sm h-100 w-100">

                    <div class="card-header bg-white">
                      <h5 class="mb-0 fw-semibold">
                        <i class="fa fa-users me-1" /> Testigo del Acto </h5>
                    </div>

                    <div class="card-body">

                      <div class="row">

                        <div class="col-md-6">
                          <div class="mb-3">
                            <p class="text-muted small">Nombre</p>
                            <field class="w-100" name="testigo_nombre" nolabel="1" />
                          </div>
                        </div>

                        <div class="col-md-6">
                          <div class="mb-3">
                            <p class="text-muted small">Cédula</p>
                            <field class="w-100" name="testigo_cedula" nolabel="1" />
                          </div>
                        </div>

                      </div>
                      <div class="row">

                        <div class="col-md-12">
                          <div class="mb-3">
                            <p class="text-muted small">Firma Testigo</p>

                            <div
                              class="border rounded p-2 d-flex justify-content-center align-items-center">
                              <field name="testigo_firma"
                                widget="image"
                                class="d-block"
                                nolabel="1" />
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>

                  </div>
                </div>

                <!-- evidencia -->
                <div class="col-lg-4 d-flex">
                  <div class="card border-0 shadow-sm h-100 w-100">

                    <div class="card-header bg-white">
                      <h5 class="mb-0 fw-semibold">
                        <i class="fa fa-camera me-1" /> Evidencias </h5>
                    </div>

                    <div class="card-body">

                       <field name="evidencia_ids"
                         context="{'form_view_ref': 'paralization_mpz.view_evidencia_form', 'default_boleta_id': active_id}"
                         domain="[('inspection_id', '=', False)]"
                         nolabel="1">
                        <tree class="table table-sm table-hover">
                          <field name="name" string="Nombre" readonly="1" />
                          <field name="tipo" string="Tipo" />
                          <field name="attachment_id" />
                        </tree>
                      </field>

                    </div>

                  </div>
                </div>

              </div>
            </div>

            <!-- Actas de inspección -->
            <div class="container-fluid mt-4">
              <div class="card border-0 shadow-sm">

                <div class="card-header bg-white">
                  <h5 class="mb-0 fw-semibold">
                    <i class="fa fa-file-text me-1" /> Actas de Inspección </h5>
                </div>

                <div class="card-body p-0">
                  <field name="inspection_ids"
                    context="{'form_view_ref': 'paralization_mpz.view_inspection_form'}"
                    nolabel="1">
                    <tree class="table table-sm table-hover">
                      <field name="name" string="N° Acta"/>
                      <field name="fecha"/>
                    </tree>
                  </field>

                </div>

              </div>
            </div>

          </sheet>

        </form>

      </field>
    </record>

  </data>
</odoo>