<odoo>
  <data>
    <record model="ir.ui.view" id="autoevaluation_survey_question_tree">
      <field name="name">ae.question.tree</field>
      <field name="model">ae.question</field>
      <field name="arch" type="xml">
        <tree>
          <field name="sequence" widget="handle"/>
          <field name="title" />
          <field name="description" />
          <field name="section_id" />
          <field name="related_components" widget="many2many_tags" string="Related Components"/> 
        </tree>
      </field>
    </record>

    <record id="autoevaluation_survey_question_form" model="ir.ui.view">
      <field name="name">ae.question.form</field>
      <field name="model">ae.question</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <div class="oe_title">
              <h1>
                <field name="title" placeholder="Question Title..." required="1"/>
              </h1>
            </div>

            <group>
              <group>
                <field name="sequence"/>
                <field name="section_id"/>
                <field name="related_components" widget="many2many_tags" readonly="1"/>
              </group>
            </group>

            <notebook>
              <page string="Detalles de la Pregunta" name="details">
                <group>
                  <field name="description" string="Description" widget="text" required="1" placeholder="Question description..."/>
                  <field name="guidance_text_justification" string="Texto de Orientación para Justificación" widget="text" placeholder="Texto de orientación opcional para ayudar a los usuarios al proporcionar justificaciones (cuando la respuesta es 'Sí')..."/>
                  <field name="guidance_text_proposed_action" string="Texto de Orientación para Acción Propuesta" widget="text" placeholder="Texto de orientación opcional para ayudar a los usuarios al proporcionar acciones propuestas (cuando la respuesta es 'No')..."/>
                </group>
              </page>
            </notebook>
          </sheet>
        </form>
      </field>
    </record>
 
    <record model="ir.actions.act_window" id="autoevaluation_question_action">
      <field name="name">Questions</field>
      <field name="res_model">ae.question</field>
      <field name="view_mode">tree,form</field>
    </record>
  </data>
</odoo>
