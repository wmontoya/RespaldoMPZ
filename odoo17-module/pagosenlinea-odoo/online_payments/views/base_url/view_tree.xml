<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_base_url_tree" model="ir.ui.view">
            <field name="name">base_url.tree</field>
            <field name="model">online_payments.base_url</field>
            <field name="arch" type="xml">
                <tree string="Base URLs">
                    <field name="id" invisible="1"/>
                    <field name="abbreviation" string="Abbreviation" required="1"/>
                    <field name="end_point" string="End Point" required="1"/>
                </tree>
            </field>
        </record>
    </data>
</odoo>
