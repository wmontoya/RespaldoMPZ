<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_base_url_form" model="ir.ui.view">
            <field name="name">base_url.form</field>
            <field name="model">online_payments.base_url</field>
            <field name="arch" type="xml">
                <form string="Base URL">
                    <sheet>
                        <group string="Base URL Information">
                            <field name="abbreviation" placeholder="Enter abbreviation" required="1"/>
                            <field name="end_point" placeholder="Enter endpoint" required="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>


