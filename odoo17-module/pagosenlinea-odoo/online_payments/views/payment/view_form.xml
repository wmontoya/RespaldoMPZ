<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_payment_form" model="ir.ui.view">
            <field name="name">payment.form</field>
            <field name="model">online_payments.payment</field>
            <field name="arch" type="xml">
                <form string="Payment" duplicate="0">
                    <sheet>
                        <group string="Payment Information">
                            <group>
                                <field name="authorization"/>
                                <field name="date_creation"/>
                                <field name="date_pay"/>
                                <field name="discount"/>
                                <field name="email"/>
                                <field name="error_reference"/>
                                <field name="identification"/>
                                <field name="interest"/>
                                <field name="invoice_real"/>
                                <field name="invoice_temp"/>
                                <field name="ip_client"/>
                                <field name="penalty"/>
                                <field name="phone"/>
                                <field name="request_id"/>
                                <field name="status_transaction_description"/>
                                <field name="sub_amount"/>
                                <field name="stamp"/>
                                <field name="token"/>
                                <field name="total_amount"/>
                                <field name="cashier_user_id"/>
                            </group>
                        </group> 
                        <notebook>
                            <page string="Payment Details">
                                <field name="payment_details_ids">
                                    <tree string="Payment Details">
                                        <field name="accounting_assistant"/> 
                                        <field name="authorization"/>
                                        <field name="standard_code"/>
                                        <field name="description"/>
                                        <field name="status"/>
                                        <field name="cutoff_date"/>
                                        <field name="item_id"/>
                                        <field name="balance_id"/>
                                        <field name="amount"/>
                                        <field name="penalty_amount"/>
                                        <field name="account_number"/>
                                        <field name="document_number"/>
                                        <field name="period"/>
                                        <field name="balance"/>
                                        <field name="interest_balance"/>
                                        <field name="transaction_type"/>
                                        <field name="year"/> 
                                    </tree> 
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>