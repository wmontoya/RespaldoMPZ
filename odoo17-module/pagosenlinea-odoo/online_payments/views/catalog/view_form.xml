<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_catalog_form" model="ir.ui.view">
            <field name="name">catalog.form</field>
            <field name="model">online_payments.catalog</field>
            <field name="arch" type="xml">
                <form string="Base URL">
                    <sheet>
                        <group string="Catalog Information">
                            <field name="prefix" />
                            <field name="code_agreement" />
                            <field name="code_bank" />
                            <field name="code_agency" />
                            <field name="identification_default" />
                            <field name="have_details" />
                            <field name="active" />
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>