<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">
        <record id="cron_job_payments" forcecreate="True" model="ir.cron">
            <field name="name">Payments Cron Job Place To Pay</field>
            <field eval="True" name="active"/>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1400</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="model_id" ref="model_online_payments_payment"/>
            <field name="state">code</field>
            <field name="code">model.start_cron_job()</field>
        </record>
    </data>
</odoo>