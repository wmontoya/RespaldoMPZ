<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_admin_user_form" model="ir.ui.view">
            <field name="name">parking_meters.user</field>
            <field name="model">res.users</field>
            <field name="arch" type="xml">
                <form string="User Group">
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                User Information
                            </h1>
                        </div>
                        <group>
                            <group>
                                <!-- Left Column -->
                                <field name="name" />
                                <field name="email" />
                                <field name="active" widget="boolean_toggle" />
                                <field name="phone_mac_direction" />
                            </group>
                            <group>
                                <!-- Right Column -->
                                <field name="login" />
                                <field name="password" password="True" />
                                <field name="updated_status" />
                            </group>
                        </group>
                        <notebook>
                            <page string="Group Permissions">
                                <field name="groups_id">
                                    <tree>
                                        <field name="name" />
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>