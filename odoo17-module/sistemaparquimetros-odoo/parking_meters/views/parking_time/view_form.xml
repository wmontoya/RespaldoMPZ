<odoo>
    <data>
        <record id="view_parking_time_form" model="ir.ui.view">
            <field name="name">parking_meters.parking_time.form</field>
            <field name="model">parking_meters.parking_time</field>
            <field name="arch" type="xml">
                <form string="Parking Time">
                    <sheet>
                        <group>
                            <field name="plate_type_id"/>
                            <field name="plate_number"/>
                            <field name="parking_rate_ids" widget="many2many_tags"/>
                            <field name="start_time"/>
                            <field name="end_time"/>
                            <field name="email"/>
                            <field name="phone"/>
                            <field name="notified"/>
                            <field name="status"/>
                            <field name="consulted"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>
