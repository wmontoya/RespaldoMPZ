<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Tree View -->
        <record id="view_ir_config_parameter_tree" model="ir.ui.view">
            <field name="name">ir.config.parameter.tree</field>
            <field name="model">ir.config_parameter</field>
            <field name="arch" type="xml">
                <tree string="parameters">
                    <field name="id"/>
                    <field name="key"/>
                    <field name="value"/>
                </tree>
            </field>
        </record>

        <!-- Action with Domain -->
        <record id="action_ir_config_parameter_tree" model="ir.actions.act_window">
            <field name="name">Parameters</field>
            <field name="res_model">ir.config_parameter</field>
            <field name="view_mode">tree</field>
            <field name="view_id" ref="view_ir_config_parameter_tree"/>
        </record>

        <!-- Menu Item -->
        <menuitem id="menu_parameter_configuration" name="Parameters" parent="base.menu_custom" action="action_ir_config_parameter_tree"/>

    </data>
</odoo>
