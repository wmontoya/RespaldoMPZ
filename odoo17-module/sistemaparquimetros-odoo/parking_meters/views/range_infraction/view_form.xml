<odoo>
    <data>
        <record id="view_range_infraction_form" model="ir.ui.view">
            <field name="name">parking_meters.range_infraction.form</field>
            <field name="model">parking_meters.range_infraction</field>
            <field name="arch" type="xml">
                <form string="Range of Infractions">
                    <sheet>
                        <group>
                            <field name="start_range"/>
                            <field name="end_range"/>
                            <field name="ticket_number"/>
                            <field name="user_code_id"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>
