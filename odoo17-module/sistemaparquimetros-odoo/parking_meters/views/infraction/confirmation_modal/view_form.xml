<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_confirmation_modal" model="ir.ui.view">
            <field name="name">parking_meters.infraction.confirmation.modal</field>
            <field name="model">parking_meters.infraction</field>
            <field name="priority" eval="50"/>
            <field name="arch" type="xml">
                <form string="" class="o_form_view o_form_view_nosidebar">
                    <div class="container">
                        <div class="text-center" style="margin: 30px 0 10px 0;">
                            <span style="font-size: 48px;">💳</span>
                            <h1 style="margin-top: 10px; color: #333;">Confirmar Pago de Infracción</h1>
                        </div>

                        <div class="text-center" style="margin: 20px;">
                            <p style="font-size: 16px; color: #666;"> Al confirmar, se registrará el
                                pago de esta infracción.<br /> Esta acción no se puede deshacer. </p>
                        </div>

                    </div>

                    <footer>
                        <div class="container">
                            <div
                                style="display: flex; justify-content: center; gap: 20px; margin-top: 20px;">
                                <button name="action_confirm"
                                    string="Confirmar"
                                    type="object"
                                    class="btn btn-success" />

                                <button string="Cancelar"
                                    special="cancel"
                                    class="btn btn-danger" />
                            </div>
                        </div>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>