<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <data noupdate="1">
    <record id="infraction_surcharge_update_cron" forcecreate="True" model="ir.cron">
      <field name="name">Update Surcharge Parking Meters</field>
      <field eval="True" name="active"/>
      <field name="user_id" ref="base.user_root"/>
      <field name="interval_number">1</field>
      <field name="interval_type">days</field>
      <field name="numbercall">-1</field>
      <field name="model_id" ref="model_parking_meters_infraction"/>
      <field name="state">code</field>
      <field name="code">model.run_surcharge_update_cron()</field>
      <field name="nextcall" eval="(DateTime.now() + relativedelta(hour=1, minute=0, second=0)).strftime('%Y-%m-%d %H:%M:%S')" />
    </record>
  </data>
</odoo>
