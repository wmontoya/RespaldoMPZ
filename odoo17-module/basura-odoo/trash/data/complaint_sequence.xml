<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Sequence for Complaints BAS-XXXXXXX-YEAR -->
        <record id="seq_trash_complaint" model="ir.sequence">
            <field name="name">Sequence of complaint</field>
            <field name="code">trash.complaint</field>
            <field name="prefix">BAS-%(year)s-</field>
            <field name="suffix"></field>
            <field name="padding">7</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="implementation">standard</field>
        </record>
    </data>
</odoo>
