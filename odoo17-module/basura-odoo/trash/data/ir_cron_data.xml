<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">
        <record id="trash_notification" forcecreate="True" model="ir.cron">
            <field name="name">Trash Notification</field>
            <field eval="True" name="active"/>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="model_id" ref="model_trash_route_subscription"/>
            <field name="state">code</field>
            <field name="code">model.send_trash_notifications()</field>
        </record>
    </data>
</odoo>