<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Action for Complaints -->
        <record id="action_trash_complaint" model="ir.actions.act_window">
            <field name="name">Complaints</field>
            <field name="res_model">trash.complaint</field>
            <field name="view_mode">tree,form</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No complaints registered yet.
                </p>
                <p>
                    Click the create button to register a new complaint.
                </p>
            </field>
        </record>
    </data>
</odoo>
