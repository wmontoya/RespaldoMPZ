@baseURL = http://localhost:10017
@contentType = application/json

### Authentication - Execute this first to get session cookie
# @name login
POST {{baseURL}}/web/session/authenticate
Content-Type: {{contentType}}

{
    "jsonrpc": "2.0",
    "method": "call",
    "params": {
        "db": "dev",
        "login": "admin",
        "password": "admin"
    }
}

